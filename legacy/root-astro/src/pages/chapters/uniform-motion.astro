---
import BaseLayout from "../../layouts/BaseLayout.astro";
import FormulaScene from "../../components/learning/FormulaScene.astro";
import UniformMotionLab from "../../components/simulations/UniformMotionLab.astro";
import Badge from "../../components/ui/Badge.astro";
import SurfaceCard from "../../components/ui/SurfaceCard.astro";
import { getEntry } from "astro:content";

const chapterEntry = await getEntry("chapters", "uniform-motion");

if (!chapterEntry) {
  throw new Error("Missing content entry: src/content/chapters/uniform-motion.json");
}

const chapter = chapterEntry.data;
const sections = chapter.sections;
---

<BaseLayout
  title={`${chapter.title} — PhysicsLab`}
  description={chapter.description}
  navItems={chapter.nav}
  brandHref="/chapters/uniform-motion/"
  brandLabel={`Глава: ${chapter.title}`}
>
  <article class="chapter-page" data-uniform-motion-chapter>
    <section class="section chapter-intro" aria-labelledby="chapter-title">
      <div>
        <div class="chapter-meta" aria-label="Статус главы">
          <Badge tone="info">{chapter.status}</Badge>
          {chapter.authorReviewRequired && <Badge tone="accent">authorReviewRequired</Badge>}
        </div>
        <h1 id="chapter-title">{chapter.title}</h1>
        <p class="chapter-lead">{chapter.lead}</p>
      </div>
      <aside class="chapter-note">
        <strong>Главная мысль</strong>
        <p>{chapter.mainIdea}</p>
      </aside>
    </section>

    <section id="lab" class="section chapter-section" aria-labelledby="lab-title">
      <div class="chapter-section__head">
        <p class="eyebrow">{sections.lab.eyebrow}</p>
        <h2 id="lab-title">{sections.lab.title}</h2>
        <p>{sections.lab.description}</p>
      </div>
      <UniformMotionLab visualTarget />
    </section>

    <section id="formula" class="section chapter-section" aria-labelledby="formula-title">
      <div class="chapter-section__head">
        <p class="eyebrow">{sections.formula.eyebrow}</p>
        <h2 id="formula-title">{sections.formula.title}</h2>
        <p>{sections.formula.description}</p>
      </div>
      <FormulaScene />
    </section>

    <section class="section chapter-two-column" aria-labelledby="mistake-title">
      <SurfaceCard>
        <p class="eyebrow">{sections.mistake.eyebrow}</p>
        <h2 id="mistake-title">{sections.mistake.title}</h2>
        {sections.mistake.body.map((paragraph) => <p>{paragraph}</p>)}
      </SurfaceCard>

      <SurfaceCard>
        <p class="eyebrow">{sections.summary.eyebrow}</p>
        <h2>{sections.summary.title}</h2>
        <ul class="chapter-list">
          {sections.summary.items.map((item) => <li>{item}</li>)}
        </ul>
      </SurfaceCard>
    </section>

    <section id="check" class="section chapter-section" aria-labelledby="check-title">
      <SurfaceCard>
        <div
          class="chapter-check"
          data-chapter-check
          data-feedback-correct={sections.check.feedback.correct}
          data-feedback-wrong={sections.check.feedback.wrong}
        >
          <div>
            <p class="eyebrow">{sections.check.eyebrow}</p>
            <h2 id="check-title">{sections.check.question}</h2>
          </div>
          <div class="chapter-answer-row" role="group" aria-label="Варианты ответа">
            {
              sections.check.answers.map((answer) => (
                <button type="button" data-check-answer={answer.id}>
                  {answer.label}
                </button>
              ))
            }
          </div>
          <p class="chapter-feedback" data-check-feedback aria-live="polite">
            {sections.check.feedback.initial}
          </p>
        </div>
      </SurfaceCard>
    </section>
  </article>
</BaseLayout>

<script>
  document.querySelectorAll<HTMLElement>("[data-chapter-check]").forEach((check) => {
    const buttons = check.querySelectorAll<HTMLButtonElement>("[data-check-answer]");
    const feedback = check.querySelector<HTMLElement>("[data-check-feedback]");
    const correctFeedback = check.dataset.feedbackCorrect ?? "";
    const wrongFeedback = check.dataset.feedbackWrong ?? "";

    buttons.forEach((button) => {
      button.addEventListener("click", () => {
        const isCorrect = button.dataset.checkAnswer === "correct";
        buttons.forEach((item) => {
          item.classList.remove("is-correct", "is-wrong");
          item.setAttribute("aria-pressed", "false");
        });
        button.classList.add(isCorrect ? "is-correct" : "is-wrong");
        button.setAttribute("aria-pressed", "true");

        if (feedback) {
          feedback.dataset.state = isCorrect ? "success" : "warning";
          feedback.textContent = isCorrect ? correctFeedback : wrongFeedback;
        }
      });
    });
  });
</script>

<style>
  .chapter-page {
    min-width: 0;
    position: relative;
  }

  :global(.topbar) {
    border-bottom-color: rgba(88, 216, 255, 0.12);
    background:
      linear-gradient(90deg, rgba(8, 14, 24, 0.62), rgba(8, 14, 24, 0.28)),
      transparent;
    backdrop-filter: blur(14px);
  }

  :global(.topbar nav a) {
    background: rgba(8, 14, 24, 0.28);
  }

  :global(#lab-background-canvas) {
    opacity: 0.24;
  }

  .chapter-intro {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(250px, 0.38fr);
    gap: var(--pl-space-5);
    align-items: end;
    padding-bottom: var(--pl-space-10);
  }

  .chapter-intro h1 {
    margin-top: var(--pl-space-4);
    margin-bottom: var(--pl-space-4);
  }

  .chapter-lead {
    max-width: 760px;
    margin-bottom: 0;
    color: var(--pl-text);
    font-size: clamp(1.08rem, 1.9vw, 1.28rem);
    line-height: 1.55;
  }

  .chapter-note {
    padding: var(--pl-space-4);
    border: 1px solid rgba(255, 216, 77, 0.18);
    border-radius: 20px;
    background:
      linear-gradient(135deg, rgba(255, 216, 77, 0.08), transparent 58%),
      rgba(16, 23, 34, 0.78);
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.025),
      inset 0 0 26px rgba(255, 216, 77, 0.025);
  }

  .chapter-note strong {
    display: block;
    margin-bottom: var(--pl-space-2);
    color: var(--pl-accent);
  }

  .chapter-note p {
    margin: 0;
    font-size: 0.98rem;
  }

  .chapter-section {
    display: grid;
    gap: var(--pl-space-5);
  }

  .chapter-section__head {
    max-width: 800px;
  }

  .chapter-section__head p:last-child {
    margin-bottom: 0;
  }

  .chapter-two-column {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--pl-space-5);
  }

  .chapter-page :global(.surface-card:not(.surface-card--lab)) {
    border-color: rgba(126, 179, 218, 0.12);
    border-radius: 22px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.032), rgba(255, 255, 255, 0.01)),
      rgba(7, 15, 28, 0.58);
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.022),
      inset 0 0 24px rgba(88, 216, 255, 0.016),
      0 16px 42px rgba(0, 0, 0, 0.16);
  }

  .chapter-list {
    display: grid;
    gap: var(--pl-space-2);
    margin-bottom: 0;
    padding-left: 1.2rem;
  }

  .chapter-check {
    display: grid;
    gap: var(--pl-space-4);
  }

  .chapter-check h2 {
    max-width: 760px;
  }

  .chapter-answer-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--pl-space-3);
  }

  .chapter-answer-row button {
    flex: 1 1 190px;
    min-height: 46px;
    padding: 10px 12px;
    border: 1px solid rgba(88, 216, 255, 0.12);
    border-radius: 14px;
    color: var(--pl-text);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.045), rgba(255, 255, 255, 0.012)),
      rgba(5, 14, 27, 0.66);
    font-weight: 900;
    text-align: left;
  }

  .chapter-answer-row button:focus-visible {
    outline: 3px solid var(--pl-accent);
    outline-offset: 4px;
  }

  .chapter-answer-row button.is-correct {
    border-color: rgba(110, 231, 168, 0.72);
    color: var(--pl-green);
    background: rgba(110, 231, 168, 0.08);
  }

  .chapter-answer-row button.is-wrong {
    border-color: rgba(255, 107, 107, 0.62);
    color: var(--pl-red);
    background: rgba(255, 107, 107, 0.08);
  }

  .chapter-feedback {
    min-height: 1.6em;
    margin: 0;
    padding: var(--pl-space-3);
    border: 1px solid rgba(88, 216, 255, 0.12);
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.026);
  }

  .chapter-feedback[data-state="success"] {
    border-color: rgba(110, 231, 168, 0.5);
  }

  .chapter-feedback[data-state="warning"] {
    border-color: rgba(255, 107, 107, 0.45);
  }

  @media (max-width: 900px) {
    .chapter-intro,
    .chapter-two-column {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 600px) {
    .chapter-intro {
      padding-top: var(--pl-space-10);
      padding-bottom: var(--pl-space-6);
    }

    .chapter-answer-row {
      display: grid;
      grid-template-columns: 1fr;
    }
  }
</style>
