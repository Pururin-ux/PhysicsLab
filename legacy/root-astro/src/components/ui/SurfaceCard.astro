---
interface Props {
  variant?: "default" | "lab" | "danger" | "success" | "mission";
}

const { variant = "default" } = Astro.props;
---

<article class:list={["surface-card", `surface-card--${variant}`]}>
  <slot />
</article>

<style>
  .surface-card {
    padding: clamp(var(--pl-space-5), 2.2vw, var(--pl-space-6));
    border: 1px solid var(--pl-border-soft);
    border-radius: var(--pl-radius);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.035), transparent 58%),
      var(--pl-surface);
    box-shadow: var(--pl-shadow-soft);
  }

  .surface-card--lab {
    border-color: rgba(88, 216, 255, 0.28);
    background:
      linear-gradient(180deg, rgba(88, 216, 255, 0.075), transparent 48%),
      #0c121b;
  }

  .surface-card--danger {
    border-color: rgba(255, 107, 107, 0.42);
    background:
      linear-gradient(135deg, rgba(255, 107, 107, 0.105), transparent 48%),
      var(--pl-surface);
  }

  .surface-card--success {
    border-color: rgba(110, 231, 168, 0.38);
    background:
      linear-gradient(135deg, rgba(110, 231, 168, 0.085), transparent 48%),
      var(--pl-surface);
  }

  .surface-card--mission {
    border-color: rgba(255, 216, 77, 0.42);
    background:
      linear-gradient(135deg, rgba(255, 216, 77, 0.075), transparent 52%),
      var(--pl-surface);
  }

  @media (max-width: 600px) {
    .surface-card {
      padding: var(--pl-space-5);
    }
  }
</style>
