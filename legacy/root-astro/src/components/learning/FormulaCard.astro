---
import Badge from "../ui/Badge.astro";
import SurfaceCard from "../ui/SurfaceCard.astro";

type Variable = {
  symbol: string;
  label: string;
  units: string;
  tone?: "position" | "velocity" | "time" | "acceleration";
};

interface Props {
  title?: string;
  formula: string;
  meaning: string;
  variables: Variable[];
  conditions?: string[];
  notFor?: string[];
  reviewStatus?: string;
}

const {
  title = "Главная формула",
  formula,
  meaning,
  variables,
  conditions = [],
  notFor = [],
  reviewStatus = "требует проверки автора"
} = Astro.props;
---

<SurfaceCard>
  <div class="card-head">
    <p class="component-label">{title}</p>
    <Badge tone="info">{reviewStatus}</Badge>
  </div>
  <div class="formula-main" aria-label={`Формула: ${formula}`}>{formula}</div>
  <p>{meaning}</p>
  <div class="formula-detail-grid" aria-label="Переменные формулы">
    {
      variables.map((item) => (
        <div class:list={["variable", item.tone ? `variable--${item.tone}` : ""]}>
          <b>{item.symbol}</b>
          <span>{item.label}, {item.units}</span>
        </div>
      ))
    }
  </div>
  {(conditions.length > 0 || notFor.length > 0) && (
    <div class="condition-row">
      {conditions.map((item) => <Badge tone="success">Работает: {item}</Badge>)}
      {notFor.map((item) => <Badge tone="danger">Не подходит: {item}</Badge>)}
    </div>
  )}
</SurfaceCard>

<style>
  .card-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--pl-space-4);
    margin-bottom: var(--pl-space-4);
  }

  .component-label {
    margin: 0;
    color: var(--pl-accent);
    font-size: 0.78rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  .formula-main {
    margin: 0 0 var(--pl-space-4);
    padding: clamp(var(--pl-space-4), 3vw, var(--pl-space-6));
    border: 1px solid rgba(88, 216, 255, 0.46);
    border-radius: var(--pl-radius);
    color: var(--pl-text);
    background:
      linear-gradient(180deg, rgba(88, 216, 255, 0.06), transparent),
      #0b1018;
    font-family: "Cascadia Mono", "JetBrains Mono", Consolas, monospace;
    font-size: clamp(2rem, 4.6vw, 3.7rem);
    font-weight: 800;
    line-height: 1.1;
    overflow-wrap: anywhere;
    text-align: center;
  }

  .formula-detail-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(132px, 1fr));
    gap: var(--pl-space-3);
    margin-top: var(--pl-space-4);
  }

  .variable {
    display: grid;
    gap: var(--pl-space-2);
    padding: var(--pl-space-4);
    border: 1px solid var(--pl-border-soft);
    border-radius: var(--pl-radius);
    background: rgba(255, 255, 255, 0.035);
  }

  .variable span {
    color: var(--pl-text-muted);
    line-height: 1.5;
  }

  .variable--position {
    border-color: rgba(88, 216, 255, 0.55);
  }

  .variable--velocity {
    border-color: rgba(255, 216, 77, 0.55);
  }

  .variable--time {
    border-color: rgba(110, 231, 168, 0.55);
  }

  .variable--acceleration {
    border-color: rgba(255, 138, 91, 0.55);
  }

  .condition-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--pl-space-2);
    margin-top: var(--pl-space-4);
  }

  @media (max-width: 840px) {
    .formula-detail-grid {
      grid-template-columns: repeat(auto-fit, minmax(132px, 1fr));
    }
  }

  @media (max-width: 460px) {
    .card-head {
      align-items: flex-start;
      flex-direction: column;
      gap: var(--pl-space-2);
    }

    .formula-main {
      font-size: clamp(1.8rem, 10vw, 2.4rem);
    }
  }
</style>
