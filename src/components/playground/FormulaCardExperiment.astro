<article
  class="formula-card-experiment"
  data-formula-card-experiment
  data-active-part="none"
  aria-labelledby="formula-card-experiment-title"
>
  <div class="formula-card-experiment__field" aria-hidden="true"></div>
  <div class="formula-card-experiment__aura" aria-hidden="true"></div>

  <header class="formula-card-experiment__header">
    <div class="formula-card-experiment__title-lockup">
      <span class="formula-card-experiment__mark" aria-hidden="true">
        <span></span>
      </span>
      <div>
        <p class="formula-card-experiment__label">Прототип карточки</p>
        <h4 id="formula-card-experiment-title">Формула</h4>
      </div>
    </div>
    <p class="formula-card-experiment__help">Наведи на символ формулы</p>
  </header>

  <section class="formula-card-experiment__scene" aria-label="Интерактивная сцена формулы и графика">
    <div class="formula-card-experiment__formula-panel" aria-label="Формула равномерного движения">
      <div class="formula-card-experiment__screen-grid" aria-hidden="true"></div>
      <div class="formula-card-experiment__screen-corners" aria-hidden="true"></div>

      <div
        class="formula-card-experiment__formula"
        aria-label="Формула: x равно x ноль плюс v умножить на t"
      >
        <button
          class="formula-card-experiment__formula-part"
          type="button"
          data-formula-part="x"
          aria-label="x — где тело окажется"
          aria-pressed="false"
        >
          x
        </button>
        <span aria-hidden="true">=</span>
        <button
          class="formula-card-experiment__formula-part"
          type="button"
          data-formula-part="x0"
          aria-label="x ноль — откуда начали"
          aria-pressed="false"
        >
          x<sub>0</sub>
        </button>
        <span aria-hidden="true">+</span>
        <span class="formula-card-experiment__term" data-fce-term>
          <button
            class="formula-card-experiment__formula-part"
            type="button"
            data-formula-part="v"
            aria-label="v — скорость"
            aria-pressed="false"
          >
            v
          </button>
          <button
            class="formula-card-experiment__formula-part"
            type="button"
            data-formula-part="t"
            aria-label="t — время"
            aria-pressed="false"
          >
            t
          </button>
          <button
            class="formula-card-experiment__term-info"
            type="button"
            data-formula-part="vt"
            aria-label="vt — изменение координаты"
            aria-pressed="false"
          >
            i
          </button>
        </span>
      </div>

      <p class="formula-card-experiment__explain">
        Сначала берём старт, потом добавляем изменение координаты за время t.
      </p>
    </div>

    <div class="formula-card-experiment__graph-panel" aria-label="График координаты от времени">
      <svg
        class="formula-card-experiment__graph"
        viewBox="0 0 520 330"
        role="img"
        aria-label="График x от t со стартовой точкой, текущей точкой и подсказками"
        focusable="false"
      >
        <g class="formula-card-experiment__grid" aria-hidden="true">
          <line x1="82" y1="52" x2="82" y2="258"></line>
          <line x1="194" y1="52" x2="194" y2="258"></line>
          <line x1="306" y1="52" x2="306" y2="258"></line>
          <line x1="418" y1="52" x2="418" y2="258"></line>
          <line x1="82" y1="219" x2="438" y2="219"></line>
          <line x1="82" y1="174" x2="438" y2="174"></line>
          <line x1="82" y1="129" x2="438" y2="129"></line>
          <line x1="82" y1="84" x2="438" y2="84"></line>
        </g>

        <line class="formula-card-experiment__axis" x1="82" y1="258" x2="455" y2="258"></line>
        <line class="formula-card-experiment__axis" x1="82" y1="258" x2="82" y2="36"></line>

        <g class="formula-card-experiment__ticks" aria-hidden="true">
          <line x1="82" y1="253" x2="82" y2="263"></line>
          <line x1="194" y1="253" x2="194" y2="263"></line>
          <line x1="306" y1="253" x2="306" y2="263"></line>
          <line x1="77" y1="258" x2="87" y2="258"></line>
          <line x1="77" y1="219" x2="87" y2="219"></line>
          <line x1="77" y1="174" x2="87" y2="174"></line>
          <line x1="77" y1="129" x2="87" y2="129"></line>
        </g>

        <g class="formula-card-experiment__tick-labels">
          <text x="76" y="283">0</text>
          <text x="188" y="283">1</text>
          <text x="300" y="283">2</text>
          <text x="49" y="263">0</text>
          <text x="49" y="224">2</text>
          <text x="49" y="179">4</text>
          <text x="49" y="134">6</text>
          <text class="formula-card-experiment__axis-label" x="92" y="28">x, м</text>
          <text class="formula-card-experiment__axis-label" x="415" y="300">t, с</text>
        </g>

        <g data-graph-element="time" class="formula-card-experiment__time-marker">
          <line x1="306" y1="258" x2="306" y2="129"></line>
          <text x="314" y="246">t</text>
        </g>

        <g data-graph-element="delta" class="formula-card-experiment__delta">
          <path d="M 328 219 C 346 219 346 129 328 129"></path>
          <line x1="320" y1="219" x2="338" y2="219"></line>
          <line x1="320" y1="129" x2="338" y2="129"></line>
        </g>
        <text
          class="formula-card-experiment__delta-label"
          data-graph-element="delta-label"
          x="352"
          y="176"
        >
          Δx = vt
        </text>

        <text
          class="formula-card-experiment__slope-label"
          data-graph-element="slope-label"
          x="188"
          y="58"
        >
          Чем больше v, тем круче линия x(t)
        </text>

        <g class="formula-card-experiment__slope-family" data-graph-element="slope-family">
          <polyline
            class="formula-card-experiment__slope-family-line formula-card-experiment__slope-family-line--slow"
            points="82,219 306,176"
          ></polyline>
          <polyline
            class="formula-card-experiment__slope-family-line formula-card-experiment__slope-family-line--fast"
            points="82,219 306,86"
          ></polyline>
        </g>

        <polyline
          class="formula-card-experiment__plot"
          data-graph-element="line"
          points="82,219 306,129"
        ></polyline>
        <circle
          class="formula-card-experiment__point-halo formula-card-experiment__point-halo--start"
          r="11"
          cx="82"
          cy="219"
        ></circle>
        <circle
          class="formula-card-experiment__point formula-card-experiment__point--start"
          data-graph-element="start"
          r="6"
          cx="82"
          cy="219"
        ></circle>
        <text
          class="formula-card-experiment__point-label"
          data-graph-element="start-label"
          x="98"
          y="244"
        >
          x₀
        </text>
        <circle
          class="formula-card-experiment__point-halo formula-card-experiment__point-halo--current"
          r="13"
          cx="306"
          cy="129"
        ></circle>
        <circle
          class="formula-card-experiment__point formula-card-experiment__point--current"
          data-graph-element="current"
          r="7"
          cx="306"
          cy="129"
        ></circle>
        <text
          class="formula-card-experiment__point-label"
          data-graph-element="current-label"
          x="318"
          y="110"
        >
          x
        </text>
      </svg>
    </div>
  </section>

  <aside
    class="formula-card-experiment__insight"
    aria-live="polite"
    aria-atomic="true"
    aria-label="Контекстная подсказка"
  >
    <span class="formula-card-experiment__insight-line" aria-hidden="true"></span>
    <div>
      <strong data-fce-insight-title>Нажми на символ формулы — увидишь, за что он отвечает.</strong>
      <p data-fce-insight>График показывает, как меняется координата, а не дорогу по карте.</p>
    </div>
  </aside>
</article>

<script>
  import { initFormulaCardExperiment } from "../../scripts/formula-card-experiment";

  const bootFormulaCards = () => {
    document
      .querySelectorAll<HTMLElement>("[data-formula-card-experiment]")
      .forEach((card) => initFormulaCardExperiment(card));
  };

  bootFormulaCards();
  document.addEventListener("astro:page-load", bootFormulaCards);
</script>

<style>
