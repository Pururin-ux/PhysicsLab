---
type Variable = {
  symbol: string;
  label: string;
  active?: boolean;
};

const variables: Variable[] = [
  { symbol: "x", label: "где тело сейчас" },
  { symbol: "x₀", label: "где стартовали" },
  { symbol: "v", label: "как быстро движется", active: true },
  { symbol: "t", label: "сколько прошло времени" }
];
---

<article
  class="formula-card-experiment"
  data-formula-card-experiment
  aria-labelledby="formula-card-experiment-title"
>
  <div class="formula-card-experiment__header">
    <div>
      <p class="formula-card-experiment__label">Прототип карточки</p>
      <h4 id="formula-card-experiment-title">Формула</h4>
    </div>
    <span class="formula-card-experiment__status">Сейчас главное: скорость v</span>
  </div>

  <div class="formula-card-experiment__formula-wrap">
    <div class="formula-card-experiment__grid" aria-hidden="true"></div>
    <p
      class="formula-card-experiment__formula"
      aria-label="Формула: x равно x ноль плюс v умножить на t"
    >
      <span>x</span>
      <span>=</span>
      <span>x₀</span>
      <span>+</span>
      <span class="formula-card-experiment__term" aria-label="v умножить на t">
        <span class="formula-card-experiment__active-token">v</span><span>t</span>
      </span>
    </p>
  </div>

  <p class="formula-card-experiment__explain">
    Сначала берём старт, потом добавляем путь за время t.
  </p>

  <div class="formula-card-experiment__variables" aria-label="Переменные формулы">
    {
      variables.map((variable) => (
        <div
          class:list={[
            "formula-card-experiment__variable",
            variable.active ? "formula-card-experiment__variable--active" : ""
          ]}
          aria-current={variable.active ? "true" : undefined}
        >
          <b>{variable.symbol}</b>
          <span>{variable.label}</span>
          {variable.active && <em>главная переменная сейчас</em>}
        </div>
      ))
    }
  </div>

  <div class="formula-card-experiment__hint" aria-label="Подсказка">
    <span aria-hidden="true"></span>
    <p>Меняй v, чтобы увидеть, как меняется график x(t).</p>
  </div>

  <div class="formula-card-experiment__outcomes" aria-label="Выводы">
    <p class="formula-card-experiment__outcome formula-card-experiment__outcome--positive">
      <span aria-hidden="true"></span>
      Линия x(t) идёт вверх, если v &gt; 0
    </p>
    <p class="formula-card-experiment__outcome">
      <span aria-hidden="true"></span>
      Если v = 0, положение не меняется
    </p>
  </div>
</article>

<style>
  .formula-card-experiment {
    position: relative;
    display: grid;
    gap: var(--pl-space-4);
    min-width: 0;
    padding: clamp(var(--pl-space-4), 3vw, var(--pl-space-6));
    overflow: hidden;
    border: 1px solid rgba(88, 216, 255, 0.28);
    border-radius: var(--pl-radius);
    background:
      linear-gradient(135deg, rgba(88, 216, 255, 0.08), transparent 38%),
      linear-gradient(180deg, rgba(255, 216, 77, 0.035), transparent 72%),
      rgba(8, 13, 22, 0.94);
    box-shadow: var(--pl-shadow-soft);
  }

  .formula-card-experiment__header {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--pl-space-4);
    min-width: 0;
  }

  .formula-card-experiment__label {
    margin: 0 0 var(--pl-space-1);
    color: var(--pl-accent);
    font-size: 0.78rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  .formula-card-experiment h4 {
    margin: 0;
    color: var(--pl-text);
    font-size: clamp(1.25rem, 2.2vw, 1.7rem);
    line-height: 1.15;
  }

  .formula-card-experiment__status {
    display: inline-flex;
    align-items: center;
    min-height: 36px;
    padding: 8px 12px;
    border: 1px solid rgba(255, 216, 77, 0.48);
    border-radius: var(--pl-radius);
    color: var(--pl-accent);
    background: rgba(255, 216, 77, 0.08);
    font-size: 0.94rem;
    font-weight: 900;
    line-height: 1.25;
  }

  .formula-card-experiment__formula-wrap {
    position: relative;
    min-width: 0;
    overflow: hidden;
    border: 1px solid rgba(88, 216, 255, 0.2);
    border-radius: var(--pl-radius);
    background: rgba(7, 12, 20, 0.72);
  }

  .formula-card-experiment__grid {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(rgba(88, 216, 255, 0.065) 1px, transparent 1px),
      linear-gradient(90deg, rgba(88, 216, 255, 0.065) 1px, transparent 1px);
    background-size: 34px 34px;
    opacity: 0.8;
    pointer-events: none;
  }

  .formula-card-experiment__formula {
    position: relative;
    z-index: 1;
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: center;
    gap: 0.22em;
    margin: 0;
    padding: clamp(var(--pl-space-5), 5vw, var(--pl-space-10)) var(--pl-space-4);
    color: var(--pl-text);
    font-family: "Cascadia Mono", "JetBrains Mono", Consolas, monospace;
    font-size: clamp(2.2rem, 8vw, 5rem);
    font-weight: 900;
    line-height: 1.05;
    text-align: center;
    text-shadow: 0 0 18px rgba(88, 216, 255, 0.18);
  }

  .formula-card-experiment__term {
    display: inline-flex;
    align-items: baseline;
    gap: 0.02em;
    padding: 0 0.08em;
    border-radius: var(--pl-radius-sm);
    background: rgba(255, 216, 77, 0.055);
    box-shadow: 0 0 0 1px rgba(255, 216, 77, 0.18);
  }

  .formula-card-experiment__active-token {
    color: var(--pl-accent);
    text-shadow: 0 0 18px rgba(255, 216, 77, 0.22);
  }

  .formula-card-experiment__explain {
    margin: 0;
    color: var(--pl-text);
    font-size: clamp(1rem, 1.6vw, 1.12rem);
    font-weight: 750;
    line-height: 1.55;
  }

  .formula-card-experiment__variables {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: var(--pl-space-3);
  }

  .formula-card-experiment__variable {
    display: grid;
    gap: var(--pl-space-2);
    min-width: 0;
    min-height: 132px;
    padding: var(--pl-space-4);
    border: 1px solid rgba(88, 216, 255, 0.24);
    border-radius: var(--pl-radius);
    background: rgba(255, 255, 255, 0.035);
  }

  .formula-card-experiment__variable b {
    color: var(--pl-cyan);
    font-family: "Cascadia Mono", "JetBrains Mono", Consolas, monospace;
    font-size: clamp(2rem, 4.5vw, 3rem);
    line-height: 1;
  }

  .formula-card-experiment__variable span {
    color: var(--pl-text-muted);
    font-size: 0.96rem;
    line-height: 1.45;
  }

  .formula-card-experiment__variable em {
    margin-top: auto;
    color: var(--pl-accent);
    font-size: 0.82rem;
    font-style: normal;
    font-weight: 900;
  }

  .formula-card-experiment__variable--active {
    border-color: rgba(255, 216, 77, 0.62);
    background:
      linear-gradient(180deg, rgba(255, 216, 77, 0.1), rgba(255, 216, 77, 0.035)),
      rgba(255, 255, 255, 0.035);
  }

  .formula-card-experiment__variable--active b {
    color: var(--pl-accent);
  }

  .formula-card-experiment__hint {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: var(--pl-space-3);
    align-items: center;
    padding: var(--pl-space-3);
    border: 1px solid rgba(88, 216, 255, 0.2);
    border-radius: var(--pl-radius);
    background: rgba(88, 216, 255, 0.045);
  }

  .formula-card-experiment__hint span,
  .formula-card-experiment__outcome span {
    display: block;
    width: 22px;
    height: 3px;
    border-radius: 999px;
    background: var(--pl-cyan);
  }

  .formula-card-experiment__hint p,
  .formula-card-experiment__outcome {
    margin: 0;
    color: var(--pl-text-muted);
    font-size: 0.98rem;
    line-height: 1.5;
  }

  .formula-card-experiment__hint p {
    color: var(--pl-text);
  }

  .formula-card-experiment__outcomes {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--pl-space-3);
  }

  .formula-card-experiment__outcome {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: var(--pl-space-3);
    align-items: center;
    min-width: 0;
    padding: var(--pl-space-3);
    border: 1px solid rgba(88, 216, 255, 0.18);
    border-radius: var(--pl-radius);
    background: rgba(255, 255, 255, 0.035);
  }

  .formula-card-experiment__outcome--positive {
    border-color: rgba(110, 231, 168, 0.36);
    color: var(--pl-text);
    background: rgba(110, 231, 168, 0.055);
  }

  .formula-card-experiment__outcome--positive span {
    height: 16px;
    border-radius: 0;
    background: none;
    border-right: 3px solid var(--pl-green);
    border-bottom: 3px solid var(--pl-green);
    transform: rotate(45deg);
  }

  @media (max-width: 760px) {
    .formula-card-experiment__header,
    .formula-card-experiment__outcomes {
      grid-template-columns: 1fr;
    }

    .formula-card-experiment__header {
      display: grid;
    }

    .formula-card-experiment__status {
      justify-self: start;
    }

    .formula-card-experiment__variables {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 430px) {
    .formula-card-experiment {
      padding: var(--pl-space-4);
    }

    .formula-card-experiment__formula {
      font-size: clamp(2rem, 13vw, 3.1rem);
      gap: 0.16em;
    }

    .formula-card-experiment__variables {
      grid-template-columns: 1fr;
    }

    .formula-card-experiment__variable {
      min-height: auto;
    }
  }
</style>
