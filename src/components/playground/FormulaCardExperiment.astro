---
type VariablePart = "x" | "x0" | "v" | "t";

type Variable = {
  part: VariablePart;
  symbol: string;
  label: string;
  detail: string;
  ariaLabel: string;
};

const variables: Variable[] = [
  {
    part: "x",
    symbol: "x",
    label: "где тело окажется",
    detail: "координата сейчас",
    ariaLabel: "Показать связь переменной x с формулой и текущей точкой графика"
  },
  {
    part: "x0",
    symbol: "x0",
    label: "откуда начали",
    detail: "стартовая координата",
    ariaLabel: "Показать связь x ноль со стартовой точкой графика"
  },
  {
    part: "v",
    symbol: "v",
    label: "скорость",
    detail: "задает наклон",
    ariaLabel: "Показать связь скорости v с членом vt и наклоном графика"
  },
  {
    part: "t",
    symbol: "t",
    label: "время",
    detail: "сколько прошло",
    ariaLabel: "Показать связь времени t с маркером времени на графике"
  }
];
---

<article
  class="formula-card-experiment"
  data-formula-card-experiment
  data-active-part="none"
  aria-labelledby="formula-card-experiment-title"
>
  <div class="formula-card-experiment__field" aria-hidden="true"></div>
  <div class="formula-card-experiment__aura" aria-hidden="true"></div>

  <header class="formula-card-experiment__header">
    <div class="formula-card-experiment__title-lockup">
      <span class="formula-card-experiment__mark" aria-hidden="true">
        <span></span>
      </span>
      <div>
        <p class="formula-card-experiment__label">Прототип карточки</p>
        <h4 id="formula-card-experiment-title">Формула</h4>
      </div>
    </div>

    <aside
      class="formula-card-experiment__status"
      aria-live="polite"
      aria-atomic="true"
      aria-label="Текущий учебный фокус"
    >
      <span class="formula-card-experiment__status-dot" aria-hidden="true"></span>
      <div>
        <strong data-fce-status-title>Наведи на часть формулы</strong>
        <p data-fce-status-sub>Выбери символ в формуле или карточку переменной.</p>
      </div>
    </aside>
  </header>

  <section class="formula-card-experiment__screen" aria-label="Экран формулы">
    <div class="formula-card-experiment__screen-grid" aria-hidden="true"></div>
    <div class="formula-card-experiment__screen-corners" aria-hidden="true"></div>
    <div
      class="formula-card-experiment__formula"
      aria-label="Формула: x равно x ноль плюс v умножить на t"
    >
      <button
        class="formula-card-experiment__formula-part"
        type="button"
        data-formula-part="x"
        aria-label="x - где тело окажется"
        aria-pressed="false"
      >
        x
      </button>
      <span aria-hidden="true">=</span>
      <button
        class="formula-card-experiment__formula-part"
        type="button"
        data-formula-part="x0"
        aria-label="x ноль - откуда начали"
        aria-pressed="false"
      >
        x<sub>0</sub>
      </button>
      <span aria-hidden="true">+</span>
      <span class="formula-card-experiment__term" aria-label="член v t">
        <button
          class="formula-card-experiment__formula-part formula-card-experiment__active-token"
          type="button"
          data-formula-part="v"
          aria-label="v - скорость"
          aria-pressed="false"
        >
          v
        </button>
        <button
          class="formula-card-experiment__formula-part"
          type="button"
          data-formula-part="t"
          aria-label="t - время"
          aria-pressed="false"
        >
          t
        </button>
      </span>
    </div>
    <button
      class="formula-card-experiment__term-control"
      type="button"
      data-formula-part="vt"
      aria-label="vt - изменение координаты за время"
      aria-pressed="false"
    >
      vt целиком
    </button>
  </section>

  <p class="formula-card-experiment__explain">
    Сначала берем старт, потом добавляем путь за время t.
  </p>

  <div class="formula-card-experiment__body">
    <section class="formula-card-experiment__variables" aria-label="Переменные формулы">
      {
        variables.map((variable) => (
          <button
            class="formula-card-experiment__variable"
            type="button"
            data-variable-card={variable.part}
            aria-label={variable.ariaLabel}
            aria-pressed="false"
          >
            <span class="formula-card-experiment__module-light" aria-hidden="true"></span>
            <b>{variable.part === "x0" ? <span>x<sub>0</sub></span> : variable.symbol}</b>
            <strong>{variable.label}</strong>
            <span>{variable.detail}</span>
          </button>
        ))
      }
    </section>

    <aside class="formula-card-experiment__insight" aria-label="Пояснение к графику">
      <div class="formula-card-experiment__mini-graph">
        <svg
          viewBox="0 0 220 128"
          class="formula-card-experiment__graph-svg"
          role="img"
          aria-label="Мини-график x от t со стартовой точкой, текущей точкой и маркером времени"
          focusable="false"
        >
          <line class="formula-card-experiment__axis" x1="28" y1="104" x2="204" y2="104"></line>
          <line class="formula-card-experiment__axis" x1="28" y1="104" x2="28" y2="18"></line>

          <g class="formula-card-experiment__ticks" aria-hidden="true">
            <line x1="72" y1="101" x2="72" y2="107"></line>
            <line x1="116" y1="101" x2="116" y2="107"></line>
            <line x1="160" y1="101" x2="160" y2="107"></line>
            <line x1="25" y1="80" x2="31" y2="80"></line>
            <line x1="25" y1="56" x2="31" y2="56"></line>
            <line x1="25" y1="32" x2="31" y2="32"></line>
          </g>

          <g class="formula-card-experiment__tick-labels">
            <text x="24" y="116">0</text>
            <text x="112" y="116">1</text>
            <text x="156" y="116">2</text>
            <text x="8" y="84">2</text>
            <text x="8" y="60">4</text>
            <text x="8" y="36">6</text>
            <text class="formula-card-experiment__axis-label" x="34" y="16">x, м</text>
            <text class="formula-card-experiment__axis-label" x="184" y="121">t, с</text>
          </g>

          <line
            class="formula-card-experiment__time-marker"
            data-graph-element="time"
            x1="184"
            y1="104"
            x2="184"
            y2="36"
          ></line>
          <line
            class="formula-card-experiment__delta-marker"
            data-graph-element="delta"
            x1="196"
            y1="88"
            x2="196"
            y2="36"
          ></line>
          <polyline
            class="formula-card-experiment__plot"
            data-graph-element="line"
            points="28,88 184,36"
          ></polyline>
          <circle
            class="formula-card-experiment__plot-point formula-card-experiment__plot-point--start"
            data-graph-element="start"
            r="4"
            cx="28"
            cy="88"
          ></circle>
          <circle
            class="formula-card-experiment__plot-point formula-card-experiment__plot-point--current"
            data-graph-element="current"
            r="4.5"
            cx="184"
            cy="36"
          ></circle>
        </svg>
      </div>
      <div>
        <strong>График показывает, как меняется координата, а не дорогу по карте.</strong>
        <p data-fce-insight>График показывает, как меняется координата x со временем t.</p>
      </div>
    </aside>
  </div>

  <div class="formula-card-experiment__hint" aria-label="Подсказка">
    <span aria-hidden="true"></span>
    <p data-fce-hint>Нажми на символ формулы - увидишь, за что он отвечает.</p>
  </div>

  <div class="formula-card-experiment__outcomes" aria-label="Выводы про знак скорости">
    <p class="formula-card-experiment__chip">
      <span class="formula-card-experiment__slope-icon" data-slope-icon aria-hidden="true">
        <svg viewBox="0 0 28 18" focusable="false">
          <line x1="3" y1="14" x2="25" y2="4"></line>
        </svg>
      </span>
      v &gt; 0 → линия вверх
    </p>
    <p class="formula-card-experiment__chip">
      <span class="formula-card-experiment__slope-icon" data-slope-icon aria-hidden="true">
        <svg viewBox="0 0 28 18" focusable="false">
          <line x1="3" y1="9" x2="25" y2="9"></line>
        </svg>
      </span>
      v = 0 → линия ровная
    </p>
    <p class="formula-card-experiment__chip">
      <span class="formula-card-experiment__slope-icon" data-slope-icon aria-hidden="true">
        <svg viewBox="0 0 28 18" focusable="false">
          <line x1="3" y1="4" x2="25" y2="14"></line>
        </svg>
      </span>
      v &lt; 0 → линия вниз
    </p>
  </div>
</article>

<script>
  import { initFormulaCardExperiment } from "../../scripts/formula-card-experiment";

  const bootFormulaCards = () => {
    document
      .querySelectorAll<HTMLElement>("[data-formula-card-experiment]")
      .forEach((card) => initFormulaCardExperiment(card));
  };

  bootFormulaCards();
  document.addEventListener("astro:page-load", bootFormulaCards);
</script>

<style>
  .formula-card-experiment {
    --card-bg: rgba(6, 12, 21, 0.96);
    --card-line: rgba(88, 216, 255, 0.3);
    --card-yellow-line: rgba(255, 216, 77, 0.44);

    position: relative;
    display: grid;
    gap: clamp(var(--pl-space-2), 1.5vw, var(--pl-space-4));
    min-width: 0;
    padding: clamp(var(--pl-space-4), 2.2vw, var(--pl-space-6));
    overflow: hidden;
    border: 1px solid var(--card-line);
    border-radius: var(--pl-radius);
    background:
      radial-gradient(circle at 18% 8%, rgba(88, 216, 255, 0.18), transparent 25rem),
      radial-gradient(circle at 84% 16%, rgba(255, 216, 77, 0.12), transparent 22rem),
      linear-gradient(180deg, rgba(255, 255, 255, 0.035), transparent 46%),
      var(--card-bg);
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.035),
      inset 0 0 44px rgba(88, 216, 255, 0.045),
      0 18px 52px rgba(0, 0, 0, 0.34);
  }

  .formula-card-experiment::before,
  .formula-card-experiment::after {
    content: "";
    position: absolute;
    pointer-events: none;
  }

  .formula-card-experiment::before {
    inset: 10px;
    border: 1px solid rgba(88, 216, 255, 0.12);
    border-radius: var(--pl-radius);
  }

  .formula-card-experiment::after {
    top: 14px;
    right: 14px;
    left: 14px;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(88, 216, 255, 0.45), transparent);
    opacity: 0.65;
  }

  .formula-card-experiment__field {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(rgba(88, 216, 255, 0.035) 1px, transparent 1px),
      linear-gradient(90deg, rgba(88, 216, 255, 0.035) 1px, transparent 1px);
    background-size: 42px 42px;
    mask-image: radial-gradient(circle at center, black, transparent 76%);
    opacity: 0.82;
    pointer-events: none;
  }

  .formula-card-experiment__aura {
    position: absolute;
    right: 8%;
    bottom: 18%;
    width: 36%;
    height: 42%;
    border: 1px solid rgba(255, 216, 77, 0.13);
    border-radius: 50%;
    transform: rotate(-10deg);
    pointer-events: none;
  }

  .formula-card-experiment__header,
  .formula-card-experiment__screen,
  .formula-card-experiment__explain,
  .formula-card-experiment__body,
  .formula-card-experiment__hint,
  .formula-card-experiment__outcomes {
    position: relative;
    z-index: 2;
  }

  .formula-card-experiment__header {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(260px, 0.42fr);
    gap: var(--pl-space-4);
    align-items: start;
  }

  .formula-card-experiment__title-lockup {
    display: flex;
    align-items: center;
    gap: var(--pl-space-3);
    min-width: 0;
  }

  .formula-card-experiment__mark {
    position: relative;
    display: grid;
    place-items: center;
    flex: 0 0 auto;
    width: 48px;
    height: 48px;
    border: 1px solid rgba(88, 216, 255, 0.38);
    border-radius: var(--pl-radius);
    background:
      radial-gradient(circle, rgba(255, 216, 77, 0.95) 0 5px, transparent 6px),
      rgba(10, 19, 31, 0.78);
  }

  .formula-card-experiment__mark::before,
  .formula-card-experiment__mark::after,
  .formula-card-experiment__mark span {
    content: "";
    position: absolute;
    width: 38px;
    height: 16px;
    border: 2px solid var(--pl-cyan);
    border-radius: 50%;
  }

  .formula-card-experiment__mark::before {
    transform: rotate(35deg);
  }

  .formula-card-experiment__mark::after {
    transform: rotate(-35deg);
  }

  .formula-card-experiment__mark span {
    border-color: var(--pl-accent);
    transform: rotate(90deg);
  }

  .formula-card-experiment__label {
    margin: 0 0 var(--pl-space-1);
    color: var(--pl-accent);
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .formula-card-experiment h4 {
    margin: 0;
    color: var(--pl-text);
    font-size: clamp(1.35rem, 2.4vw, 1.9rem);
    line-height: 1.05;
  }

  .formula-card-experiment__status {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: var(--pl-space-3);
    align-items: center;
    min-width: 0;
    padding: var(--pl-space-2) var(--pl-space-3);
    border: 1px solid var(--card-yellow-line);
    border-radius: var(--pl-radius);
    background:
      linear-gradient(135deg, rgba(255, 216, 77, 0.11), transparent 58%),
      rgba(14, 18, 24, 0.84);
    box-shadow: inset 0 0 24px rgba(255, 216, 77, 0.045);
  }

  .formula-card-experiment__status-dot {
    display: grid;
    place-items: center;
    width: 28px;
    height: 28px;
    border: 2px solid var(--pl-accent);
    border-radius: 50%;
  }

  .formula-card-experiment__status-dot::before {
    content: "";
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--pl-accent);
    box-shadow: 0 0 12px rgba(255, 216, 77, 0.3);
  }

  .formula-card-experiment__status strong {
    display: block;
    color: var(--pl-accent);
    font-size: 0.94rem;
    line-height: 1.25;
  }

  .formula-card-experiment__status p {
    margin: var(--pl-space-1) 0 0;
    color: var(--pl-text);
    font-size: 0.88rem;
    line-height: 1.4;
  }

  .formula-card-experiment__screen {
    min-width: 0;
    overflow: hidden;
    border: 1px solid rgba(88, 216, 255, 0.5);
    border-radius: var(--pl-radius);
    background:
      linear-gradient(180deg, rgba(88, 216, 255, 0.07), rgba(88, 216, 255, 0.018)),
      #07101b;
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.04),
      inset 0 0 38px rgba(88, 216, 255, 0.08),
      0 0 24px rgba(88, 216, 255, 0.08);
  }

  .formula-card-experiment__screen-grid {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(rgba(88, 216, 255, 0.075) 1px, transparent 1px),
      linear-gradient(90deg, rgba(88, 216, 255, 0.075) 1px, transparent 1px);
    background-size: 38px 38px;
    opacity: 0.78;
    pointer-events: none;
  }

  .formula-card-experiment__screen-corners::before,
  .formula-card-experiment__screen-corners::after {
    content: "";
    position: absolute;
    width: 11px;
    height: 11px;
    border-color: var(--pl-cyan);
    pointer-events: none;
  }

  .formula-card-experiment__screen-corners::before {
    top: 16px;
    left: 16px;
    border-top: 2px solid;
    border-left: 2px solid;
  }

  .formula-card-experiment__screen-corners::after {
    right: 16px;
    bottom: 16px;
    border-right: 2px solid;
    border-bottom: 2px solid;
  }

  .formula-card-experiment__formula {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 0.25em;
    margin: 0;
    padding: clamp(var(--pl-space-6), 4.4vw, var(--pl-space-12)) var(--pl-space-4) var(--pl-space-4);
    color: var(--pl-text);
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(2.45rem, 7vw, 5.25rem);
    font-style: italic;
    font-weight: 700;
    line-height: 1;
    white-space: nowrap;
    text-shadow:
      0 0 10px rgba(244, 247, 251, 0.18),
      0 0 24px rgba(88, 216, 255, 0.16);
  }

  .formula-card-experiment__formula-part,
  .formula-card-experiment__term-control {
    border: 1px solid transparent;
    color: inherit;
    background: transparent;
    font: inherit;
    line-height: inherit;
    text-shadow: inherit;
    cursor: pointer;
    transition:
      border-color 0.18s ease,
      background 0.18s ease,
      color 0.18s ease,
      box-shadow 0.18s ease,
      transform 0.18s ease;
  }

  .formula-card-experiment__formula-part {
    padding: 0 0.04em;
    border-radius: var(--pl-radius-sm);
  }

  .formula-card-experiment__formula-part:hover,
  .formula-card-experiment__formula-part:focus-visible,
  .formula-card-experiment__term-control:hover,
  .formula-card-experiment__term-control:focus-visible {
    outline: 3px solid rgba(255, 216, 77, 0.55);
    outline-offset: 3px;
  }

  .formula-card-experiment__formula sub,
  .formula-card-experiment__variable b sub {
    font-size: 0.48em;
    line-height: 0;
    margin-left: 0.02em;
    vertical-align: -0.24em;
  }

  .formula-card-experiment__term {
    display: inline-flex;
    align-items: baseline;
    gap: 0.02em;
    padding: 0 0.08em 0.02em;
    border: 1px solid rgba(255, 216, 77, 0.2);
    border-radius: var(--pl-radius-sm);
    background:
      radial-gradient(circle at 36% 50%, rgba(255, 216, 77, 0.16), transparent 55%),
      rgba(255, 216, 77, 0.035);
  }

  .formula-card-experiment__active-token {
    color: var(--pl-accent);
  }

  .formula-card-experiment__term-control {
    position: relative;
    z-index: 2;
    justify-self: center;
    margin: 0 0 var(--pl-space-3);
    padding: 6px 12px;
    border-color: rgba(88, 216, 255, 0.26);
    border-radius: 999px;
    color: var(--pl-text-muted);
    background: rgba(8, 14, 24, 0.72);
    font-family: inherit;
    font-size: 0.82rem;
    font-style: normal;
    font-weight: 850;
    line-height: 1.2;
    text-shadow: none;
  }

  .formula-card-experiment__formula-part[data-active],
  .formula-card-experiment__term-control[data-active] {
    border-color: rgba(255, 216, 77, 0.42);
    color: var(--pl-accent);
    background: rgba(255, 216, 77, 0.09);
    box-shadow:
      inset 0 0 18px rgba(255, 216, 77, 0.08),
      0 0 18px rgba(255, 216, 77, 0.11);
    transform: translateY(-1px);
  }

  .formula-card-experiment__explain {
    margin: 0;
    padding: 0 var(--pl-space-2);
    color: var(--pl-text);
    font-size: clamp(0.98rem, 1.45vw, 1.08rem);
    font-weight: 750;
    line-height: 1.42;
  }

  .formula-card-experiment__body {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(280px, 0.42fr);
    gap: var(--pl-space-4);
    align-items: stretch;
  }

  .formula-card-experiment__variables {
    position: relative;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: var(--pl-space-3);
  }

  .formula-card-experiment__variable {
    position: relative;
    display: grid;
    grid-template-rows: auto auto auto 1fr;
    gap: var(--pl-space-2);
    min-width: 0;
    min-height: 128px;
    padding: var(--pl-space-3);
    overflow: hidden;
    border: 1px solid rgba(88, 216, 255, 0.28);
    border-radius: var(--pl-radius);
    color: inherit;
    background:
      linear-gradient(180deg, rgba(88, 216, 255, 0.06), transparent 64%),
      rgba(10, 17, 28, 0.88);
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.025),
      inset 0 -18px 32px rgba(0, 0, 0, 0.12);
    text-align: left;
    cursor: pointer;
    transition:
      border-color 0.18s ease,
      background 0.18s ease,
      box-shadow 0.18s ease,
      transform 0.18s ease;
  }

  .formula-card-experiment__variable:focus-visible {
    outline: 3px solid rgba(255, 216, 77, 0.55);
    outline-offset: 3px;
  }

  .formula-card-experiment__variable::after {
    content: "";
    position: absolute;
    right: var(--pl-space-3);
    bottom: var(--pl-space-3);
    left: var(--pl-space-3);
    height: 2px;
    border-radius: 999px;
    background: linear-gradient(90deg, var(--pl-cyan), transparent);
    opacity: 0.64;
  }

  .formula-card-experiment__module-light {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--pl-cyan);
    box-shadow: 0 0 16px rgba(88, 216, 255, 0.3);
  }

  .formula-card-experiment__variable b {
    color: var(--pl-cyan);
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(2rem, 3.5vw, 2.9rem);
    font-style: italic;
    line-height: 0.9;
    text-shadow: 0 0 18px rgba(88, 216, 255, 0.18);
  }

  .formula-card-experiment__variable b span {
    color: inherit;
    font: inherit;
    line-height: inherit;
  }

  .formula-card-experiment__variable strong {
