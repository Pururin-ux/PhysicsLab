---
type Variable = {
  symbol: string;
  label: string;
  detail: string;
  active?: boolean;
};

const variables: Variable[] = [
  { symbol: "x", label: "где тело сейчас", detail: "координата" },
  { symbol: "x0", label: "старт", detail: "откуда начали" },
  { symbol: "v", label: "скорость", detail: "как быстро движется", active: true },
  { symbol: "t", label: "время", detail: "сколько прошло" }
];
---

<article
  class="formula-card-experiment"
  data-formula-card-experiment
  data-motion-state="forward"
  aria-labelledby="formula-card-experiment-title"
>
  <div class="formula-card-experiment__field" aria-hidden="true"></div>
  <div class="formula-card-experiment__aura" aria-hidden="true"></div>

  <header class="formula-card-experiment__header">
    <div class="formula-card-experiment__title-lockup">
      <span class="formula-card-experiment__mark" aria-hidden="true">
        <span></span>
      </span>
      <div>
        <p class="formula-card-experiment__label">Прототип карточки</p>
        <h4 id="formula-card-experiment-title">Формула</h4>
      </div>
    </div>

    <aside
      class="formula-card-experiment__status"
      aria-live="polite"
      aria-atomic="true"
      aria-label="Текущее наблюдение за скоростью"
    >
      <span class="formula-card-experiment__status-dot" aria-hidden="true"></span>
      <div>
        <strong data-fce-status-title>Скорость v &gt; 0</strong>
        <p data-fce-status-sub>Чем больше v, тем круче линия x(t)</p>
      </div>
    </aside>
  </header>

  <section class="formula-card-experiment__screen" aria-label="Экран формулы">
    <div class="formula-card-experiment__screen-grid" aria-hidden="true"></div>
    <div class="formula-card-experiment__screen-corners" aria-hidden="true"></div>
    <p
      class="formula-card-experiment__formula"
      aria-label="Формула: x равно x ноль плюс v умножить на t"
    >
      <span data-fce-part="x">x</span>
      <span>=</span>
      <span data-fce-part="x0">x<sub>0</sub></span>
      <span>+</span>
      <span class="formula-card-experiment__term" data-fce-part="vt" aria-label="v умножить на t">
        <span class="formula-card-experiment__active-token">v</span><span>t</span>
      </span>
    </p>
  </section>

  <p class="formula-card-experiment__explain">
    Сначала берём старт, потом добавляем путь за время t.
  </p>

  <div class="formula-card-experiment__body">
    <section class="formula-card-experiment__variables" aria-label="Переменные формулы">
      {
        variables.map((variable) => (
          <div
            class:list={[
              "formula-card-experiment__variable",
              variable.active ? "formula-card-experiment__variable--active" : ""
            ]}
            aria-current={variable.active ? "true" : undefined}
          >
            <span class="formula-card-experiment__module-light" aria-hidden="true"></span>
            <b>{variable.symbol === "x0" ? <span>x<sub>0</sub></span> : variable.symbol}</b>
            <strong>{variable.label}</strong>
            <span>{variable.detail}</span>
            {variable.active && <em>активная переменная</em>}
          </div>
        ))
      }
    </section>

    <aside class="formula-card-experiment__insight" aria-label="Пояснение к графику">
      <div class="formula-card-experiment__mini-graph" aria-hidden="true">
        <svg viewBox="0 0 120 56" class="formula-card-experiment__graph-svg" focusable="false">
          <line class="formula-card-experiment__axis" x1="10" y1="46" x2="110" y2="46"></line>
          <line class="formula-card-experiment__axis" x1="10" y1="46" x2="10" y2="10"></line>
          <polyline class="formula-card-experiment__plot" data-fce-plot points="10,46 110,16"></polyline>
          <circle class="formula-card-experiment__plot-dot" data-fce-plot-dot r="3.5" cx="10" cy="46"></circle>
        </svg>
        <span class="formula-card-experiment__graph-label">x(t)</span>
      </div>
      <div>
        <strong>График координаты от времени, не путь по карте.</strong>
        <p data-fce-insight>Наклон прямой на x(t) равен скорости v.</p>
        <p class="formula-card-experiment__v-readout">
          Пример: <span data-fce-v-token>v = +5 м/с</span>
        </p>
      </div>
    </aside>
  </div>

  <div class="formula-card-experiment__hint" aria-label="Подсказка">
    <span aria-hidden="true"></span>
    <p data-fce-hint>Смотри: при положительной v координата растёт со временем.</p>
  </div>

  <div class="formula-card-experiment__outcomes" aria-label="Выводы">
    <p
      class="formula-card-experiment__chip formula-card-experiment__chip--positive formula-card-experiment__chip--live"
      data-fce-chip="forward"
      aria-current="true"
    >
      <span aria-hidden="true"></span>
      v &gt; 0 — вверх
    </p>
    <p class="formula-card-experiment__chip" data-fce-chip="still">
      <span aria-hidden="true"></span>
      v = 0 — ровно
    </p>
    <p class="formula-card-experiment__chip formula-card-experiment__chip--backward" data-fce-chip="backward">
      <span aria-hidden="true"></span>
      v &lt; 0 — вниз
    </p>
  </div>
</article>

<script>
  import { initFormulaCardExperiment } from "../../scripts/formula-card-experiment";

  const bootFormulaCard = () => {
    initFormulaCardExperiment(
      document.querySelector<HTMLElement>("[data-formula-card-experiment]")
    );
  };

  bootFormulaCard();
  document.addEventListener("astro:page-load", bootFormulaCard);
</script>

<style>
  .formula-card-experiment {
    --card-bg: rgba(6, 12, 21, 0.96);
    --card-line: rgba(88, 216, 255, 0.3);
    --card-line-soft: rgba(88, 216, 255, 0.14);
    --card-yellow-line: rgba(255, 216, 77, 0.44);

    position: relative;
    display: grid;
    gap: clamp(var(--pl-space-2), 1.5vw, var(--pl-space-4));
    min-width: 0;
    padding: clamp(var(--pl-space-4), 2.2vw, var(--pl-space-6));
    overflow: hidden;
    border: 1px solid var(--card-line);
    border-radius: var(--pl-radius);
    background:
      radial-gradient(circle at 18% 8%, rgba(88, 216, 255, 0.18), transparent 25rem),
      radial-gradient(circle at 84% 16%, rgba(255, 216, 77, 0.12), transparent 22rem),
      linear-gradient(180deg, rgba(255, 255, 255, 0.035), transparent 46%),
      var(--card-bg);
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.035),
      inset 0 0 44px rgba(88, 216, 255, 0.045),
      0 18px 52px rgba(0, 0, 0, 0.34);
  }

  .formula-card-experiment::before,
  .formula-card-experiment::after {
    content: "";
    position: absolute;
    pointer-events: none;
  }

  .formula-card-experiment::before {
    inset: 10px;
    border: 1px solid rgba(88, 216, 255, 0.12);
    border-radius: var(--pl-radius);
  }

  .formula-card-experiment::after {
    top: 14px;
    right: 14px;
    left: 14px;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(88, 216, 255, 0.45), transparent);
    opacity: 0.65;
  }

  .formula-card-experiment__field {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(rgba(88, 216, 255, 0.035) 1px, transparent 1px),
      linear-gradient(90deg, rgba(88, 216, 255, 0.035) 1px, transparent 1px);
    background-size: 42px 42px;
    mask-image: radial-gradient(circle at center, black, transparent 76%);
    opacity: 0.82;
    pointer-events: none;
  }

  .formula-card-experiment__aura {
    position: absolute;
    right: 8%;
    bottom: 18%;
    width: 36%;
    height: 42%;
    border: 1px solid rgba(255, 216, 77, 0.13);
    border-radius: 50%;
    transform: rotate(-10deg);
    pointer-events: none;
  }

  .formula-card-experiment__header,
  .formula-card-experiment__screen,
  .formula-card-experiment__explain,
  .formula-card-experiment__body,
  .formula-card-experiment__hint,
  .formula-card-experiment__outcomes {
    position: relative;
    z-index: 2;
  }

  .formula-card-experiment__header {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(260px, 0.42fr);
    gap: var(--pl-space-4);
    align-items: start;
  }

  .formula-card-experiment__title-lockup {
    display: flex;
    align-items: center;
    gap: var(--pl-space-3);
    min-width: 0;
  }

  .formula-card-experiment__mark {
    position: relative;
    display: grid;
    place-items: center;
    flex: 0 0 auto;
    width: 48px;
    height: 48px;
    border: 1px solid rgba(88, 216, 255, 0.38);
    border-radius: var(--pl-radius);
    background:
      radial-gradient(circle, rgba(255, 216, 77, 0.95) 0 5px, transparent 6px),
      rgba(10, 19, 31, 0.78);
  }

  .formula-card-experiment__mark::before,
  .formula-card-experiment__mark::after,
  .formula-card-experiment__mark span {
    content: "";
    position: absolute;
    width: 38px;
    height: 16px;
    border: 2px solid var(--pl-cyan);
    border-radius: 50%;
  }

  .formula-card-experiment__mark::before {
    transform: rotate(35deg);
  }

  .formula-card-experiment__mark::after {
    transform: rotate(-35deg);
  }

  .formula-card-experiment__mark span {
    border-color: var(--pl-accent);
    transform: rotate(90deg);
  }

  .formula-card-experiment__label {
    margin: 0 0 var(--pl-space-1);
    color: var(--pl-accent);
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .formula-card-experiment h4 {
    margin: 0;
    color: var(--pl-text);
    font-size: clamp(1.35rem, 2.4vw, 1.9rem);
    line-height: 1.05;
  }

  .formula-card-experiment__status {
    display: grid;
    grid-template-columns: auto minmax(0, 1fr);
    gap: var(--pl-space-3);
    align-items: center;
    min-width: 0;
    padding: var(--pl-space-2) var(--pl-space-3);
    border: 1px solid var(--card-yellow-line);
    border-radius: var(--pl-radius);
    background:
      linear-gradient(135deg, rgba(255, 216, 77, 0.11), transparent 58%),
      rgba(14, 18, 24, 0.84);
    box-shadow: inset 0 0 24px rgba(255, 216, 77, 0.045);
  }

  .formula-card-experiment__status-dot {
    display: grid;
    place-items: center;
    width: 28px;
    height: 28px;
    border: 2px solid var(--pl-accent);
    border-radius: 50%;
  }

  .formula-card-experiment__status-dot::before {
    content: "";
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--pl-accent);
    box-shadow: 0 0 16px rgba(255, 216, 77, 0.42);
  }

  .formula-card-experiment__status strong {
    display: block;
    color: var(--pl-accent);
    font-size: 0.94rem;
    line-height: 1.25;
  }

  .formula-card-experiment__status p {
    margin: var(--pl-space-1) 0 0;
    color: var(--pl-text);
    font-size: 0.88rem;
    line-height: 1.4;
  }

  .formula-card-experiment__screen {
    min-width: 0;
    overflow: hidden;
    border: 1px solid rgba(88, 216, 255, 0.5);
    border-radius: var(--pl-radius);
    background:
      linear-gradient(180deg, rgba(88, 216, 255, 0.07), rgba(88, 216, 255, 0.018)),
      #07101b;
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.04),
      inset 0 0 38px rgba(88, 216, 255, 0.08),
      0 0 24px rgba(88, 216, 255, 0.08);
  }

  .formula-card-experiment__screen-grid {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(rgba(88, 216, 255, 0.075) 1px, transparent 1px),
      linear-gradient(90deg, rgba(88, 216, 255, 0.075) 1px, transparent 1px);
    background-size: 38px 38px;
    opacity: 0.78;
    pointer-events: none;
  }

  .formula-card-experiment__screen-corners::before,
  .formula-card-experiment__screen-corners::after {
    content: "";
    position: absolute;
    width: 11px;
    height: 11px;
    border-color: var(--pl-cyan);
    pointer-events: none;
  }

  .formula-card-experiment__screen-corners::before {
    top: 16px;
    left: 16px;
    border-top: 2px solid;
    border-left: 2px solid;
  }

  .formula-card-experiment__screen-corners::after {
    right: 16px;
    bottom: 16px;
    border-right: 2px solid;
    border-bottom: 2px solid;
  }

  .formula-card-experiment__formula {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 0.25em;
    margin: 0;
    padding: clamp(var(--pl-space-6), 4.6vw, var(--pl-space-12)) var(--pl-space-4);
    color: var(--pl-text);
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(2.45rem, 7vw, 5.25rem);
    font-style: italic;
    font-weight: 700;
    line-height: 1;
    white-space: nowrap;
    text-shadow:
      0 0 10px rgba(244, 247, 251, 0.18),
      0 0 24px rgba(88, 216, 255, 0.16);
  }

  .formula-card-experiment__formula sub,
  .formula-card-experiment__variable b sub {
    font-size: 0.48em;
    line-height: 0;
    margin-left: 0.02em;
    vertical-align: -0.24em;
  }

  .formula-card-experiment__term {
    display: inline-flex;
    align-items: baseline;
    gap: 0.02em;
    padding: 0 0.08em 0.02em;
    border: 1px solid rgba(255, 216, 77, 0.2);
    border-radius: var(--pl-radius-sm);
    background:
      radial-gradient(circle at 36% 50%, rgba(255, 216, 77, 0.22), transparent 55%),
      rgba(255, 216, 77, 0.045);
    box-shadow:
      inset 0 0 22px rgba(255, 216, 77, 0.08),
      0 0 24px rgba(255, 216, 77, 0.09);
  }

  .formula-card-experiment__active-token {
    color: var(--pl-accent);
    text-shadow:
      0 0 10px rgba(255, 216, 77, 0.32),
      0 0 24px rgba(255, 216, 77, 0.2);
    transition: transform 0.45s ease, color 0.45s ease;
  }


  .formula-card-experiment__term {
    transition:
      border-color 0.65s ease,
      background 0.65s ease,
      box-shadow 0.65s ease;
  }

  .formula-card-experiment[data-motion-state="forward"] .formula-card-experiment__term,
  .formula-card-experiment[data-motion-state="backward"] .formula-card-experiment__term {
    box-shadow:
      inset 0 0 22px rgba(255, 216, 77, 0.1),
      0 0 20px rgba(255, 216, 77, 0.12);
  }

  .formula-card-experiment[data-motion-state="still"] .formula-card-experiment__term {
    border-color: rgba(88, 216, 255, 0.28);
    box-shadow: inset 0 0 18px rgba(88, 216, 255, 0.06);
  }

  .formula-card-experiment__part--pulse {
    color: var(--pl-accent);
    text-shadow: 0 0 18px rgba(255, 216, 77, 0.45);
    animation: fce-part-glow 1.1s ease-in-out;
  }

  @keyframes fce-part-glow {
    0%,
    100% {
      transform: scale(1);
      filter: brightness(1);
    }
    50% {
      transform: scale(1.06);
      filter: brightness(1.2);
    }
  }

  .formula-card-experiment .formula-card-experiment__active-token {
    animation: fce-v-breathe 2.2s ease-in-out infinite;
  }

  @keyframes fce-v-breathe {
    0%,
    100% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.07);
    }
  }

  .formula-card-experiment__status-dot::before {
    animation: fce-status-pulse 2.2s ease-in-out infinite;
  }

  @keyframes fce-status-pulse {
    0%,
    100% {
      transform: scale(1);
      opacity: 1;
    }
    50% {
      transform: scale(1.15);
      opacity: 0.82;
    }
  }

  .formula-card-experiment__chip--live {
    border-color: rgba(255, 216, 77, 0.62) !important;
    background:
      linear-gradient(90deg, rgba(255, 216, 77, 0.14), transparent 72%),
      rgba(255, 255, 255, 0.05) !important;
    box-shadow: 0 0 18px rgba(255, 216, 77, 0.1);
  }

  .formula-card-experiment__chip--backward {
    border-color: rgba(255, 138, 91, 0.32);
  }

  .formula-card-experiment__chip--backward.formula-card-experiment__chip--live {
    border-color: rgba(255, 138, 91, 0.62) !important;
    background:
      linear-gradient(90deg, rgba(255, 138, 91, 0.14), transparent 72%),
      rgba(255, 255, 255, 0.05) !important;
  }

  .formula-card-experiment__chip--backward span {
    border-right-color: #ff8a5b;
    border-bottom-color: #ff8a5b;
    transform: rotate(-45deg) translateY(-2px);
  }


  .formula-card-experiment__explain {
    margin: 0;
    padding: 0 var(--pl-space-2);
    color: var(--pl-text);
    font-size: clamp(0.98rem, 1.45vw, 1.08rem);
    font-weight: 750;
    line-height: 1.42;
  }

  .formula-card-experiment__body {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(250px, 0.36fr);
    gap: var(--pl-space-4);
    align-items: stretch;
  }

  .formula-card-experiment__variables {
    position: relative;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: var(--pl-space-3);
  }

  .formula-card-experiment__variable {
    position: relative;
    display: grid;
    grid-template-rows: auto auto auto 1fr;
    gap: var(--pl-space-2);
    min-width: 0;
    min-height: 128px;
    padding: var(--pl-space-3);
    overflow: hidden;
    border: 1px solid rgba(88, 216, 255, 0.28);
    border-radius: var(--pl-radius);
    background:
      linear-gradient(180deg, rgba(88, 216, 255, 0.06), transparent 64%),
      rgba(10, 17, 28, 0.88);
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.025),
      inset 0 -18px 32px rgba(0, 0, 0, 0.12);
  }

  .formula-card-experiment__variable::after {
    content: "";
    position: absolute;
    right: var(--pl-space-3);
    bottom: var(--pl-space-3);
    left: var(--pl-space-3);
    height: 2px;
    border-radius: 999px;
    background: linear-gradient(90deg, var(--pl-cyan), transparent);
    opacity: 0.64;
  }

  .formula-card-experiment__module-light {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    background: var(--pl-cyan);
    box-shadow: 0 0 16px rgba(88, 216, 255, 0.3);
  }

  .formula-card-experiment__variable b {
    color: var(--pl-cyan);
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(2rem, 3.5vw, 2.9rem);
    font-style: italic;
    line-height: 0.9;
    text-shadow: 0 0 18px rgba(88, 216, 255, 0.18);
  }

  .formula-card-experiment__variable b span {
    color: inherit;
    font: inherit;
    line-height: inherit;
  }

  .formula-card-experiment__variable strong {
    color: var(--pl-text);
    font-size: 0.9rem;
    line-height: 1.3;
  }

  .formula-card-experiment__variable span:not(.formula-card-experiment__module-light) {
    color: var(--pl-text-muted);
    font-size: 0.84rem;
    line-height: 1.35;
  }

  .formula-card-experiment__variable em {
    align-self: end;
    color: var(--pl-accent);
    font-size: 0.76rem;
    font-style: normal;
    font-weight: 900;
    line-height: 1.25;
  }

  .formula-card-experiment__variable--active {
    border-color: rgba(255, 216, 77, 0.78);
    background:
      radial-gradient(circle at 50% 0%, rgba(255, 216, 77, 0.22), transparent 48%),
      linear-gradient(180deg, rgba(255, 216, 77, 0.11), rgba(255, 216, 77, 0.035)),
      rgba(17, 19, 23, 0.9);
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.035),
      inset 0 0 26px rgba(255, 216, 77, 0.055),
      0 0 18px rgba(255, 216, 77, 0.08);
  }

  .formula-card-experiment__variable--active::after {
    background: linear-gradient(90deg, var(--pl-accent), transparent);
  }

  .formula-card-experiment__variable--active .formula-card-experiment__module-light {
    background: var(--pl-accent);
    box-shadow: 0 0 18px rgba(255, 216, 77, 0.42);
  }

  .formula-card-experiment__variable--active b {
    color: var(--pl-accent);
    text-shadow: 0 0 20px rgba(255, 216, 77, 0.24);
  }

  .formula-card-experiment__insight {
    display: grid;
    gap: var(--pl-space-3);
    align-content: start;
    min-width: 0;
    padding: var(--pl-space-3);
    border: 1px solid rgba(88, 216, 255, 0.22);
    border-radius: var(--pl-radius);
    background:
      linear-gradient(135deg, rgba(88, 216, 255, 0.08), transparent 62%),
      rgba(10, 16, 26, 0.78);
  }

  .formula-card-experiment__mini-graph {
    position: relative;
    min-height: 72px;
    overflow: hidden;
    border: 1px solid rgba(88, 216, 255, 0.15);
    border-radius: var(--pl-radius-sm);
    background:
      linear-gradient(rgba(88, 216, 255, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(88, 216, 255, 0.04) 1px, transparent 1px);
    background-size: 18px 18px;
  }

  .formula-card-experiment__graph-svg {
    display: block;
    width: 100%;
    height: 72px;
  }

  .formula-card-experiment__axis {
    stroke: rgba(88, 216, 255, 0.28);
    stroke-width: 1;
  }

  .formula-card-experiment__plot {
    fill: none;
    stroke: var(--pl-cyan);
    stroke-width: 3;
    stroke-linecap: round;
    stroke-linejoin: round;
    transition: stroke 0.55s ease;
  }

  .formula-card-experiment[data-motion-state="forward"] .formula-card-experiment__plot {
    stroke: var(--pl-accent);
