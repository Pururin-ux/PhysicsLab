  <aside class="formula-scene__insight pl-quiz-console" aria-live="polite" aria-atomic="true">
    <span aria-hidden="true"></span>
    <div>
      <strong data-scene-insight-title>Нажми на v, t или x₀.</strong>
      <p data-scene-insight>Формула коротко записывает движение: откуда стартуем и сколько успели проехать.</p>
    </div>
  </aside>
</section>

<script>
  type ScenePart = "none" | "x" | "x0" | "v" | "t" | "vt";

  type SceneCopy = {
    title: string;
    text: string;
    formula: ScenePart[];
    graph: string[];
    relatedTerm?: boolean;
  };

  const COPY: Record<ScenePart, SceneCopy> = {
    none: {
      title: "Нажми на v, t или x₀.",
      text: "Формула коротко записывает движение: откуда стартуем и сколько успели проехать.",
      formula: [],
      graph: []
    },
    x: {
      title: "x — координата тела в выбранный момент.",
      text: "Жёлтая точка на графике показывает это значение.",
      formula: ["x"],
      graph: ["current", "current-label"]
    },
    x0: {
      title: "x₀ — стартовая координата.",
      text: "Это место, откуда начали при t = 0.",
      formula: ["x0"],
      graph: ["start", "start-label"]
    },
    v: {
      title: "v задаёт наклон графика.",
      text: "Чем больше скорость, тем круче линия x(t).",
      formula: ["v"],
      graph: ["line", "slope-family"],
      relatedTerm: true
    },
    t: {
      title: "t — сколько времени прошло.",
      text: "На графике время движет текущую точку вправо.",
      formula: ["t"],
      graph: ["time"],
      relatedTerm: true
    },
    vt: {
      title: "vt — сколько метров точка успела проехать.",
      text: "Здесь vt читаем как Δx: насколько координата изменилась за время t.",
      formula: ["vt"],
      graph: ["delta"]
    }
  };

  const toPart = (value: string | undefined): ScenePart =>
    value === "x" || value === "x0" || value === "v" || value === "t" || value === "vt"
      ? value
      : "none";

  document.querySelectorAll<HTMLElement>("[data-formula-scene]").forEach((scene) => {
    if (scene.dataset.ready === "true") return;
    scene.dataset.ready = "true";

    const parts = Array.from(scene.querySelectorAll<HTMLElement>("[data-scene-part]"));
    const graphItems = Array.from(scene.querySelectorAll<SVGElement>("[data-scene-graph]"));
    const term = scene.querySelector<HTMLElement>("[data-scene-term]");
    const title = scene.querySelector<HTMLElement>("[data-scene-insight-title]");
    const text = scene.querySelector<HTMLElement>("[data-scene-insight]");
    const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

    let selected: ScenePart = "none";
    let hovered: ScenePart = "none";
    let focused: ScenePart = "none";
    let hasRendered = false;
    let timer: number | undefined;

    const activePart = () => focused !== "none" ? focused : hovered !== "none" ? hovered : selected;

    const setCopy = (copy: SceneCopy) => {
      const update = () => {
        if (title) title.textContent = copy.title;
        if (text) text.textContent = copy.text;
      };

      if (timer) window.clearTimeout(timer);

      if (reducedMotion.matches || !hasRendered) {
        update();
        scene.dataset.insightPhase = "in";
        return;
      }

      scene.dataset.insightPhase = "out";
      timer = window.setTimeout(() => {
        update();
        scene.dataset.insightPhase = "in";
      }, 90);
    };

    const render = () => {
      const part = activePart();
      const copy = COPY[part];
      scene.dataset.activePart = part;
      setCopy(copy);

      parts.forEach((item) => {
        const itemPart = toPart(item.dataset.scenePart);
        const active = copy.formula.includes(itemPart);
        item.toggleAttribute("data-active", active);
        item.setAttribute("aria-pressed", String(active || selected === itemPart));
      });

      graphItems.forEach((item) => {
        item.toggleAttribute(
          "data-active",
          copy.graph.includes(item.getAttribute("data-scene-graph") ?? "")
        );
      });

      term?.toggleAttribute("data-related", Boolean(copy.relatedTerm));
      hasRendered = true;
    };

    const setPart = (element: HTMLElement, mode: "hover" | "focus" | "select") => {
      const part = toPart(element.dataset.scenePart);
      if (mode === "hover") hovered = part;
      if (mode === "focus") focused = part;
      if (mode === "select") selected = selected === part ? "none" : part;
      render();
    };

    parts.forEach((item) => {
      item.addEventListener("pointerenter", () => setPart(item, "hover"));
      item.addEventListener("pointerleave", () => {
        hovered = "none";
        render();
      });
      item.addEventListener("focus", () => setPart(item, "focus"));
      item.addEventListener("blur", () => {
        focused = "none";
        render();
      });
      item.addEventListener("click", () => setPart(item, "select"));
      item.addEventListener("keydown", (event) => {
        if (event.key === "Escape") {
          selected = "none";
          hovered = "none";
          focused = "none";
          render();
        }
      });
    });

    render();
  });
</script>

