  <div class="formula-scene__copy">
    <p class="formula-scene__label">Формула движения</p>
    <h3 id="formula-scene-title">Формула записывает то, что ты увидел</h3>
    <p>
      В лаборатории точка ехала. Здесь видно: старт x₀ плюс то, что точка успела проехать.
    </p>
  </div>

  <div class="formula-scene__board">
    <div class="formula-scene__formula-panel pl-formula-glow" aria-label="Формула равномерного движения">
      <div class="formula-scene__formula" aria-label="x равно x ноль плюс v умножить на t">
        <button type="button" data-scene-part="x" aria-label="x — координата в выбранный момент">
          x
        </button>
        <span aria-hidden="true">=</span>
        <button type="button" data-scene-part="x0" aria-label="x ноль — стартовая координата">
          x<sub>0</sub>
        </button>
        <span aria-hidden="true">+</span>
        <span class="formula-scene__term" data-scene-term>
          <button type="button" data-scene-part="v" aria-label="v — скорость">v</button>
          <button type="button" data-scene-part="t" aria-label="t — время">t</button>
        </span>
      </div>
      <button
        type="button"
        class="formula-scene__delta-button"
        data-scene-part="vt"
        aria-label="vt — сколько метров точка успела проехать"
      >
        Δx = vt
      </button>
    </div>

    <figure class="formula-scene__graph-panel pl-instrument-graph">
      <figcaption>График x(t)</figcaption>
      <svg
        class="formula-scene__graph"
        viewBox="0 0 420 260"
        role="img"
        aria-label="График x от t со стартовой точкой, текущей точкой и подсказками"
        focusable="false"
      >
        <g class="formula-scene__grid" aria-hidden="true">
          <line x1="64" y1="206" x2="362" y2="206"></line>
          <line x1="64" y1="158" x2="362" y2="158"></line>
          <line x1="64" y1="110" x2="362" y2="110"></line>
          <line x1="64" y1="62" x2="362" y2="62"></line>
          <line x1="64" y1="38" x2="64" y2="206"></line>
          <line x1="163" y1="38" x2="163" y2="206"></line>
          <line x1="262" y1="38" x2="262" y2="206"></line>
          <line x1="361" y1="38" x2="361" y2="206"></line>
        </g>

        <line class="formula-scene__axis" x1="64" y1="206" x2="378" y2="206"></line>
        <line class="formula-scene__axis" x1="64" y1="206" x2="64" y2="28"></line>

        <g class="formula-scene__ticks" aria-hidden="true">
          <text x="58" y="229">0</text>
          <text x="157" y="229">1</text>
          <text x="256" y="229">2</text>
          <text x="43" y="211">0</text>
          <text x="43" y="163">2</text>
          <text x="43" y="115">4</text>
          <text x="43" y="67">6</text>
          <text class="formula-scene__axis-label" x="72" y="24">x, м</text>
          <text class="formula-scene__axis-label" x="334" y="244">t, с</text>
        </g>

        <g class="formula-scene__slope-family" data-scene-graph="slope-family">
          <polyline points="64,158 262,122"></polyline>
          <polyline points="64,158 262,66"></polyline>
          <text x="168" y="46">больше v — круче линия</text>
        </g>

        <g class="formula-scene__time-marker" data-scene-graph="time">
          <line x1="262" y1="206" x2="262" y2="62"></line>
          <text x="270" y="195">t</text>
        </g>

        <g class="formula-scene__delta" data-scene-graph="delta">
          <path d="M 282 158 C 300 158 300 62 282 62"></path>
          <line x1="274" y1="158" x2="292" y2="158"></line>
          <line x1="274" y1="62" x2="292" y2="62"></line>
          <text x="306" y="112">Δx = vt</text>
        </g>

        <polyline
          class="formula-scene__plot"
          data-scene-graph="line"
          points="64,158 262,62"
        ></polyline>

        <circle class="formula-scene__point-halo formula-scene__point-halo--start" cx="64" cy="158" r="11"></circle>
        <circle class="formula-scene__point formula-scene__point--start" data-scene-graph="start" cx="64" cy="158" r="6"></circle>
        <text class="formula-scene__point-label" data-scene-graph="start-label" x="78" y="177">x₀</text>

        <circle class="formula-scene__point-halo formula-scene__point-halo--current" cx="262" cy="62" r="12"></circle>
        <circle class="formula-scene__point formula-scene__point--current" data-scene-graph="current" cx="262" cy="62" r="7"></circle>
