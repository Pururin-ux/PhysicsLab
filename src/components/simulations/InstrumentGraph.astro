---
import {
  createTicks,
  DEFAULT_GRAPH_HEIGHT,
  DEFAULT_GRAPH_PADDING,
  DEFAULT_GRAPH_WIDTH,
  mapToGraphPoint
} from "../../lib/physics/graphView";
import type { GraphDomain, GraphTick } from "../../lib/physics/graphView";

interface Props {
  title: string;
  ariaLabel: string;
  xAxisLabel: string;
  yAxisLabel: string;
  graphKind: "x" | "v";
  note: string;
  variant?: "main" | "detail";
  domain?: GraphDomain;
  xTicks?: GraphTick[];
  yTicks?: GraphTick[];
  showZeroLine?: boolean;
  showProjection?: boolean;
  projectionLabel?: string;
  showTickLabels?: boolean;
}

const {
  title,
  ariaLabel,
  xAxisLabel,
  yAxisLabel,
  graphKind,
  note,
  variant = "main",
  domain = {
    xMin: 0,
    xMax: 8,
    yMin: -24,
    yMax: 24
  },
  xTicks = createTicks(domain.xMin, domain.xMax, 5, (value) => `${value}`),
  yTicks = createTicks(domain.yMin, domain.yMax, 5, (value) => `${value}`),
  showZeroLine = true,
  showProjection = false,
  projectionLabel = graphKind,
  showTickLabels = false
} = Astro.props;

const width = DEFAULT_GRAPH_WIDTH;
const height = DEFAULT_GRAPH_HEIGHT;
const pad = DEFAULT_GRAPH_PADDING;
const plotLeft = pad.left;
const plotRight = width - pad.right;
const plotTop = pad.top;
const plotBottom = height - pad.bottom;
const canShowZeroLine = showZeroLine && domain.yMin <= 0 && domain.yMax >= 0;
const verticalGridLines = xTicks.map((tick) => ({
  ...tick,
  x: mapToGraphPoint(tick.value, domain.yMin, domain).x
}));
const horizontalGridLines = yTicks.map((tick) => ({
  ...tick,
  y: mapToGraphPoint(domain.xMin, tick.value, domain).y
}));
const zeroLineY = canShowZeroLine
  ? mapToGraphPoint(domain.xMin, 0, domain).y
  : null;
---

<figure class:list={["graph-card", `graph-card--${variant}`, "pl-instrument-graph"]}>
  <figcaption>{title}</figcaption>
  <svg
    viewBox="0 0 320 220"
    role="img"
    aria-label={ariaLabel}
    preserveAspectRatio="xMidYMid meet"
  >
    <g class="grid-lines" data-grid={graphKind} aria-hidden="true">
      {
        verticalGridLines.map((line) => (
          <line class="grid-line" x1={line.x} y1={plotTop} x2={line.x} y2={plotBottom}></line>
        ))
      }
      {
        horizontalGridLines.map((line) => (
          <line class="grid-line" x1={plotLeft} y1={line.y} x2={plotRight} y2={line.y}></line>
        ))
      }
      {
        zeroLineY !== null && (
          <line class="zero-line" x1={plotLeft} y1={zeroLineY} x2={plotRight} y2={zeroLineY}></line>
        )
      }
    </g>
    <line class="axis-line" x1={plotLeft} y1={plotBottom} x2={plotRight} y2={plotBottom}></line>
    <line class="axis-line" x1={plotLeft} y1={plotTop} x2={plotLeft} y2={plotBottom}></line>
    {
      showTickLabels && (
        <g class="graph-tick-labels" aria-hidden="true">
          {
            verticalGridLines.map((tick) => (
              <text class="graph-tick-label graph-tick-label--x" x={tick.x} y="205">{tick.label}</text>
            ))
          }
          {
            horizontalGridLines.map((tick) => (
              <text class="graph-tick-label graph-tick-label--y" x="34" y={tick.y + 3}>{tick.label}</text>
            ))
          }
        </g>
      )
    }
    <text class="axis-text" x="282" y="210">{xAxisLabel}</text>
    <text class="axis-text" x="14" y="28">{yAxisLabel}</text>
    {
      showProjection && (
        <g class="graph-projection" data-projection={graphKind} aria-hidden="true">
          <line data-projection-line="time" x1={plotLeft} y1={plotBottom} x2={plotLeft} y2={plotBottom}></line>
          <line data-projection-line="position" x1={plotLeft} y1={plotBottom} x2={plotLeft} y2={plotBottom}></line>
          <text data-projection-label={graphKind} x={plotLeft + 8} y={plotBottom - 10}>{projectionLabel}</text>
        </g>
      )
    }
    <polyline class="graph-polyline graph-polyline--base" data-polyline={graphKind}></polyline>
    <polyline class="graph-polyline graph-polyline--current" data-current-polyline={graphKind}></polyline>
    <circle class="graph-current" data-point={graphKind} r="5"></circle>
  </svg>
  <p data-graph-note={graphKind}>{note}</p>
</figure>

<style>
  .graph-card {
    min-width: 0;
    margin: 0;
    padding: var(--pl-space-4);
    border: 1px solid rgba(88, 216, 255, 0.24);
    border-radius: 12px;
    background:
      linear-gradient(180deg, rgba(88, 216, 255, 0.055), transparent 54%),
      radial-gradient(circle at 50% 18%, rgba(88, 216, 255, 0.06), transparent 24rem),
      rgba(3, 13, 27, 0.78);
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.03),
      inset 0 0 30px rgba(88, 216, 255, 0.025),
      0 16px 42px rgba(0, 0, 0, 0.22);
  }

  .graph-card figcaption {
    margin-bottom: var(--pl-space-2);
    color: var(--pl-text);
    font-size: 1.08rem;
    font-weight: 900;
  }

  .graph-card svg {
    display: block;
    width: 100%;
    max-width: 100%;
    min-height: 260px;
    margin-bottom: var(--pl-space-3);
    overflow: visible;
  }

  .graph-card p {
    margin: 0;
    font-size: 0.96rem;
    line-height: 1.55;
  }

  .graph-card :global(.grid-line) {
    stroke: rgba(168, 190, 213, 0.12);
    stroke-width: 1;
  }

  .graph-card :global(.zero-line) {
    stroke: rgba(244, 247, 251, 0.26);
    stroke-dasharray: 5 5;
    stroke-width: 1.2;
  }

  .axis-line {
    stroke: rgba(244, 247, 251, 0.62);
    stroke-width: 1.5;
  }

  .axis-text {
    fill: var(--pl-text-muted);
    font-size: 12px;
    font-weight: 700;
  }

  .graph-tick-labels text {
    fill: rgba(191, 204, 218, 0.72);
    font-size: 10px;
    font-weight: 800;
  }

  .graph-tick-label--x {
    text-anchor: middle;
  }

  .graph-tick-label--y {
    text-anchor: end;
  }

  .graph-projection line {
    stroke: rgba(255, 216, 77, 0.42);
    stroke-dasharray: 5 6;
    stroke-width: 1.4;
  }

  .graph-projection text {
    fill: var(--pl-accent);
    font-size: 11px;
    font-weight: 900;
    paint-order: stroke;
    stroke: rgba(7, 14, 24, 0.94);
    stroke-width: 3px;
  }

  .graph-polyline {
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .graph-polyline--base {
    stroke: rgba(88, 216, 255, 0.28);
    stroke-width: 2.2;
  }

  .graph-polyline--current {
    stroke: var(--pl-cyan);
    stroke-width: 4;
  }

  .graph-current {
    fill: var(--pl-accent);
    stroke: rgba(255, 249, 214, 0.92);
    stroke-width: 3.4;
    filter:
      drop-shadow(0 0 6px rgba(255, 216, 77, 0.38))
      drop-shadow(0 0 14px rgba(255, 216, 77, 0.16));
  }

  .graph-card--detail {
    grid-column: 1 / -1;
  }

  .graph-card--detail svg {
    height: clamp(220px, 28vw, 320px);
    min-height: 220px;
  }

  :global(.uniform-lab[data-visual-target="v1"]) .graph-card--main {
    border-color: rgba(88, 216, 255, 0.2);
    border-radius: 20px;
    background:
      radial-gradient(ellipse at 48% 8%, rgba(88, 216, 255, 0.13), transparent 24rem),
      linear-gradient(180deg, rgba(255, 255, 255, 0.045), rgba(255, 255, 255, 0.012)),
      rgba(4, 13, 26, 0.76);
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.03),
      inset 0 0 34px rgba(88, 216, 255, 0.04),
      0 20px 60px rgba(0, 0, 0, 0.26);
  }

  :global(.uniform-lab[data-visual-target="v1"]) .graph-card p {
    color: rgba(214, 226, 240, 0.82);
    font-weight: 520;
  }

  :global(.uniform-lab[data-visual-target="v1"]) .graph-card--main svg {
    min-height: clamp(310px, 32vw, 410px);
  }

  :global(.uniform-lab[data-visual-target="v1"]) .axis-line {
    stroke: rgba(222, 241, 255, 0.66);
    stroke-width: 1.7;
  }

  :global(.uniform-lab[data-visual-target="v1"]) .graph-card :global(.grid-line) {
    stroke: rgba(88, 216, 255, 0.1);
  }

  :global(.uniform-lab[data-visual-target="v1"]) .graph-polyline--base {
    stroke: rgba(88, 216, 255, 0.22);
    stroke-width: 2;
  }

  :global(.uniform-lab[data-visual-target="v1"]) .graph-polyline--current {
    stroke: rgba(88, 216, 255, 0.96);
    stroke-width: 4.6;
    filter: drop-shadow(0 0 8px rgba(88, 216, 255, 0.32));
  }

  :global(.uniform-lab[data-visual-target="v1"]) .graph-current {
    r: 7.8px;
    filter:
      drop-shadow(0 0 8px rgba(255, 216, 77, 0.48))
      drop-shadow(0 0 18px rgba(255, 216, 77, 0.18));
  }

  @media (max-width: 600px) {
    .graph-card svg {
      min-height: 230px;
    }

    :global(.uniform-lab[data-visual-target="v1"]) .graph-card {
      padding: var(--pl-space-3);
      border-radius: 18px;
    }

    :global(.uniform-lab[data-visual-target="v1"]) .graph-card--main svg {
      min-height: 330px;
    }
  }
</style>
