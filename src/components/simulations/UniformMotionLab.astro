---
import Badge from "../ui/Badge.astro";
import SurfaceCard from "../ui/SurfaceCard.astro";
---

<SurfaceCard variant="lab">
  <section
    class="uniform-lab"
    data-uniform-motion-lab
    aria-labelledby="uniform-lab-title"
  >
    <div class="lab-heading">
      <div>
        <p class="component-label">Интерактивная лаборатория</p>
        <h3 id="uniform-lab-title">Лаборатория равномерного движения</h3>
        <p class="lab-goal">Свяжи формулу, график и движение точки.</p>
      </div>
      <Badge tone="info">демо-режим · требует проверки автора</Badge>
    </div>

    <div class="cycle-grid" aria-label="Учебный цикл лаборатории">
      <article class="cycle-card">
        <span class="cycle-step">1</span>
        <h4>Предскажи</h4>
        <p>Что произойдёт с наклоном графика x(t), если увеличить скорость?</p>
      </article>
      <article class="cycle-card">
        <span class="cycle-step">2</span>
        <h4>Измени</h4>
        <p>Поменяй x₀, v или t и смотри, как связаны число, формула и график.</p>
      </article>
      <article class="cycle-card">
        <span class="cycle-step">3</span>
        <h4>Наблюдай</h4>
        <p>График x(t) меняет наклон, а v(t) остаётся горизонтальным.</p>
      </article>
      <article class="cycle-card">
        <span class="cycle-step">4</span>
        <h4>Объясни</h4>
        <p>Сформулируй: что показывает наклон и почему график не траектория?</p>
      </article>
    </div>

    <div class="lab-layout">
      <div class="lab-control-column">
        <div class="formula-panel" aria-label="Формула равномерного движения">
          <p class="panel-label">Главная формула</p>
          <div class="live-formula" aria-live="polite">
            <span>x</span>
            <span>=</span>
            <span class="formula-token" data-formula-token="x0">x₀</span>
            <span>+</span>
            <span class="formula-term" data-formula-token="vt">
              <span class="formula-token" data-formula-token="v">v</span><span class="formula-token" data-formula-token="t">t</span>
            </span>
          </div>
          <p class="formula-note">
            Координата равна старту плюс изменение координаты за время t.
          </p>
          <div class="substitution-box" aria-live="polite">
            <p class="substitution-title">Подстановка</p>
            <p class="substitution-line">
              x =
              <span data-formula-highlight="x0" data-substitution="x0">0</span>
              +
              <span data-formula-highlight="vt">
                <span data-formula-highlight="v" data-substitution="v">2</span>
                ·
                <span data-formula-highlight="t" data-substitution="t">0</span>
              </span>
              =
              <strong data-substitution="x">0 м</strong>
            </p>
            <p class="substitution-delta">
              Изменение координаты:
              <b data-formula-highlight="vt" data-substitution="delta">0 м</b>
            </p>
          </div>
        </div>

        <div class="scenario-row" aria-label="Сценарии движения">
          <button type="button" data-scenario="forward" aria-pressed="true">вперёд</button>
          <button type="button" data-scenario="still" aria-pressed="false">стоит</button>
          <button type="button" data-scenario="backward" aria-pressed="false">назад</button>
        </div>

        <div class="time-panel" aria-label="Управление временем">
          <div class="time-actions">
            <button
              type="button"
              class="play-button"
              data-play-toggle
              aria-pressed="false"
              aria-label="Запустить анимацию"
            >
              Запустить
            </button>
            <button type="button" class="reset-button" data-reset>
              Сбросить
            </button>
          </div>
          <p class="time-readout">
            Текущее время:
            <b data-time-readout>0 с</b>
          </p>
          <p class="motion-mode-note" data-motion-mode-note>
            При запуске время идёт до 8 с и останавливается.
          </p>
        </div>

        <div class="sliders" aria-label="Параметры движения">
          <label class="slider-field">
            <span>
              <b>x₀</b>
              <span>начальная координата</span>
            </span>
            <output data-output="x0">0 м</output>
            <input
              type="range"
              min="-6"
              max="6"
              step="0.5"
              value="0"
              data-input="x0"
              aria-label="Начальная координата x ноль в метрах"
            />
          </label>

          <label class="slider-field">
            <span>
              <b>v</b>
              <span>скорость</span>
            </span>
            <output data-output="v">2 м/с</output>
            <input
              type="range"
              min="-4"
              max="4"
              step="0.5"
              value="2"
              data-input="v"
              aria-label="Скорость v в метрах в секунду"
            />
          </label>

          <label class="slider-field">
            <span>
              <b>t</b>
              <span>ручная перемотка времени</span>
            </span>
            <output data-output="t">0 с</output>
            <input
              type="range"
              min="0"
              max="8"
              step="0.01"
              value="0"
              data-input="t"
              aria-label="Ручная перемотка времени t в секундах"
            />
          </label>
        </div>

        <div class="value-panel" aria-label="Текущие численные значения">
          <p class="panel-label">Текущее значение</p>
          <div class="value-grid">
            <div><span>x₀</span><b data-value="x0">0 м</b></div>
            <div><span>v</span><b data-value="v">2 м/с</b></div>
            <div><span>t</span><b data-value="t">0 с</b></div>
            <div><span>x</span><b data-value="x">0 м</b></div>
            <div class="value-wide"><span>Изменение координаты vt</span><b data-value="delta">0 м</b></div>
          </div>
        </div>
      </div>

      <div class="lab-observe-column">
        <div class="motion-strip" aria-label="Движение точки по прямой">
          <div class="strip-head">
            <span>Движение точки</span>
            <strong data-observation>v &gt; 0: координата растёт</strong>
          </div>
          <div class="track" aria-hidden="true">
            <span class="track-axis"></span>
            <span class="track-zero">0</span>
            <span class="velocity-arrow" data-velocity-arrow></span>
            <span class="motion-point" data-motion-point></span>
          </div>
          <p>
            Точка показывает положение x в выбранный момент времени. Это движение вдоль оси,
            а не линия графика.
          </p>
        </div>

        <div class="graphs-grid">
          <figure class="graph-card">
            <figcaption>График x(t)</figcaption>
            <svg
              viewBox="0 0 320 220"
              role="img"
              aria-label="График координаты от времени"
              preserveAspectRatio="xMidYMid meet"
            >
              <g class="grid-lines" data-grid="x"></g>
              <line class="axis-line" x1="42" y1="188" x2="302" y2="188"></line>
              <line class="axis-line" x1="42" y1="18" x2="42" y2="188"></line>
              <text class="axis-text" x="282" y="210">t, с</text>
              <text class="axis-text" x="14" y="28">x, м</text>
              <polyline class="graph-polyline graph-polyline--base" data-polyline="x"></polyline>
              <polyline class="graph-polyline graph-polyline--current" data-current-polyline="x"></polyline>
              <circle class="graph-current" data-point="x" r="5"></circle>
            </svg>
            <p data-graph-note="x">
              Текущая точка показывает координату в выбранный момент времени.
            </p>
          </figure>

          <figure class="graph-card">
            <figcaption>График v(t)</figcaption>
            <svg
              viewBox="0 0 320 220"
              role="img"
              aria-label="График скорости от времени"
              preserveAspectRatio="xMidYMid meet"
            >
              <g class="grid-lines" data-grid="v"></g>
              <line class="axis-line" x1="42" y1="188" x2="302" y2="188"></line>
              <line class="axis-line" x1="42" y1="18" x2="42" y2="188"></line>
              <text class="axis-text" x="282" y="210">t, с</text>
              <text class="axis-text" x="14" y="28">v, м/с</text>
              <polyline class="graph-polyline graph-polyline--base" data-polyline="v"></polyline>
              <polyline class="graph-polyline graph-polyline--current" data-current-polyline="v"></polyline>
              <circle class="graph-current" data-point="v" r="5"></circle>
            </svg>
            <p data-graph-note="v">При равномерном движении скорость постоянна.</p>
          </figure>
        </div>
      </div>
    </div>

    <div class="explain-card" aria-labelledby="uniform-check-title">
      <div>
        <p class="panel-label">Мини-проверка</p>
        <h4 id="uniform-check-title">
          Что произойдёт с наклоном графика x(t), если увеличить скорость?
        </h4>
      </div>
      <div class="answer-row" role="group" aria-label="Варианты ответа">
        <button type="button" data-answer="correct">Линия станет круче</button>
        <button type="button" data-answer="flat">Линия станет горизонтальной</button>
        <button type="button" data-answer="path">График станет траекторией тела</button>
      </div>
      <p class="feedback" data-feedback aria-live="polite">
        Выбери вариант, а лаборатория даст мягкую обратную связь.
      </p>
    </div>
  </section>
</SurfaceCard>

<script>
  import {
    clampNumber,
    formatPhysicsNumber,
    generatePartialUniformMotionSeries,
    generatePartialUniformVelocitySeries,
    generateUniformMotionSeries,
    generateUniformVelocitySeries,
    getUniformMotionDirection,
    normalizeUniformMotionTime,
    uniformPosition
  } from "../../lib/physics/kinematics";

  type LabState = { x0: number; v: number; t: number };
  type InputName = keyof LabState;
  type Domain = { min: number; max: number };
  type SvgPoint = { x: number; y: number };

  const SVG_WIDTH = 320;
  const SVG_HEIGHT = 220;
  const PAD = { left: 42, right: 18, top: 18, bottom: 32 };
  const T_MAX = 8;
  const X_DOMAIN: Domain = { min: -24, max: 24 };
  const V_DOMAIN: Domain = { min: -4.5, max: 4.5 };
  const PLAYBACK_RATE = 1;
  const REDUCED_MOTION_STEP = 0.5;

  const scenarios = {
    forward: { x0: 0, v: 2, t: 0 },
    still: { x0: 2, v: 0, t: 0 },
    backward: { x0: 4, v: -2, t: 0 }
  } satisfies Record<string, LabState>;

  type ScenarioName = keyof typeof scenarios;

  document.querySelectorAll<HTMLElement>("[data-uniform-motion-lab]").forEach((lab) => {
    const inputs = {
      x0: mustFind<HTMLInputElement>(lab, '[data-input="x0"]'),
      v: mustFind<HTMLInputElement>(lab, '[data-input="v"]'),
      t: mustFind<HTMLInputElement>(lab, '[data-input="t"]')
    };

    const outputs = {
      x0: mustFind<HTMLOutputElement>(lab, '[data-output="x0"]'),
      v: mustFind<HTMLOutputElement>(lab, '[data-output="v"]'),
      t: mustFind<HTMLOutputElement>(lab, '[data-output="t"]')
    };

    const values = {
      x0: mustFind<HTMLElement>(lab, '[data-value="x0"]'),
      v: mustFind<HTMLElement>(lab, '[data-value="v"]'),
      t: mustFind<HTMLElement>(lab, '[data-value="t"]'),
      x: mustFind<HTMLElement>(lab, '[data-value="x"]'),
      delta: mustFind<HTMLElement>(lab, '[data-value="delta"]')
    };

    const substitution = {
      x0: mustFind<HTMLElement>(lab, '[data-substitution="x0"]'),
      v: mustFind<HTMLElement>(lab, '[data-substitution="v"]'),
      t: mustFind<HTMLElement>(lab, '[data-substitution="t"]'),
      delta: mustFind<HTMLElement>(lab, '[data-substitution="delta"]'),
      x: mustFind<HTMLElement>(lab, '[data-substitution="x"]')
    };

    const xBaseLine = mustFind<SVGPolylineElement>(lab, '[data-polyline="x"]');
    const vBaseLine = mustFind<SVGPolylineElement>(lab, '[data-polyline="v"]');
    const xCurrentLine = mustFind<SVGPolylineElement>(lab, '[data-current-polyline="x"]');
    const vCurrentLine = mustFind<SVGPolylineElement>(lab, '[data-current-polyline="v"]');
    const xPoint = mustFind<SVGCircleElement>(lab, '[data-point="x"]');
    const vPoint = mustFind<SVGCircleElement>(lab, '[data-point="v"]');
    const motionPoint = mustFind<HTMLElement>(lab, "[data-motion-point]");
    const velocityArrow = mustFind<HTMLElement>(lab, "[data-velocity-arrow]");
    const observation = mustFind<HTMLElement>(lab, "[data-observation]");
    const xNote = mustFind<HTMLElement>(lab, '[data-graph-note="x"]');
    const vNote = mustFind<HTMLElement>(lab, '[data-graph-note="v"]');
    const playButton = mustFind<HTMLButtonElement>(lab, "[data-play-toggle]");
    const resetButton = mustFind<HTMLButtonElement>(lab, "[data-reset]");
    const timeReadout = mustFind<HTMLElement>(lab, "[data-time-readout]");
    const motionModeNote = mustFind<HTMLElement>(lab, "[data-motion-mode-note]");
    const scenarioButtons = lab.querySelectorAll<HTMLButtonElement>("[data-scenario]");
    const answerButtons = lab.querySelectorAll<HTMLButtonElement>("[data-answer]");
    const feedback = mustFind<HTMLElement>(lab, "[data-feedback]");
    const reducedMotionQuery = window.matchMedia("(prefers-reduced-motion: reduce)");

    let state: LabState = { ...scenarios.forward };
    let isPlaying = false;
    let isReducedMotion = reducedMotionQuery.matches;
    let animationFrameId: number | null = null;
    let previousFrameTime: number | null = null;

    drawGrid(lab.querySelector<SVGGElement>('[data-grid="x"]'), X_DOMAIN.min, X_DOMAIN.max);
    drawGrid(lab.querySelector<SVGGElement>('[data-grid="v"]'), V_DOMAIN.min, V_DOMAIN.max);

    const syncInputs = () => {
      inputs.x0.value = formatPhysicsNumber(state.x0);
      inputs.v.value = formatPhysicsNumber(state.v);
      inputs.t.value = formatPhysicsNumber(state.t, 2);
    };

    const setState = (nextState: LabState, changed: InputName = "x0") => {
      state = normalizeState(nextState);
      updateLab(changed);
    };

    const setActiveScenario = (name: ScenarioName | "") => {
      scenarioButtons.forEach((button) => {
        const active = button.dataset.scenario === name;
        button.setAttribute("aria-pressed", String(active));
      });
    };

    const stopAnimation = () => {
      if (animationFrameId !== null) {
        window.cancelAnimationFrame(animationFrameId);
        animationFrameId = null;
      }

      previousFrameTime = null;
      isPlaying = false;
      updatePlaybackControls();
    };

    const startAnimation = () => {
      if (isReducedMotion) {
        stepForward();
        return;
      }

      if (state.t >= T_MAX) {
        state = normalizeState({ ...state, t: 0 });
      }

      isPlaying = true;
      previousFrameTime = null;
      updateLab("t", { fromPlayback: true });
      animationFrameId = window.requestAnimationFrame(tickAnimation);
    };

    const stepForward = () => {
      stopAnimation();
      const nextT = state.t >= T_MAX
        ? 0
        : normalizeUniformMotionTime(state.t + REDUCED_MOTION_STEP, T_MAX);
      state = normalizeState({ ...state, t: nextT });
      setActiveScenario("");
      updateLab("t");
    };

    const tickAnimation = (timestamp: number) => {
      if (!isPlaying) return;

      if (previousFrameTime === null) {
        previousFrameTime = timestamp;
      }

      const deltaSeconds = ((timestamp - previousFrameTime) / 1000) * PLAYBACK_RATE;
      previousFrameTime = timestamp;
      const nextT = normalizeUniformMotionTime(state.t + deltaSeconds, T_MAX);
      state = normalizeState({ ...state, t: nextT });
      updateLab("t", { fromPlayback: true });

      if (nextT >= T_MAX) {
        stopAnimation();
        return;
      }

      animationFrameId = window.requestAnimationFrame(tickAnimation);
    };

    const updatePlaybackControls = () => {
      lab.dataset.playing = String(isPlaying);
      lab.dataset.animationState = isPlaying ? "running" : "paused";

      if (isReducedMotion) {
        playButton.textContent = "Шаг вперёд";
        playButton.setAttribute("aria-label", "Шаг вперёд по времени");
        playButton.setAttribute("aria-pressed", "false");
        playButton.dataset.mode = "step";
        motionModeNote.textContent = "Сниженное движение: кнопка делает шаг, ручная перемотка работает полностью.";
        return;
      }

      playButton.textContent = isPlaying ? "Пауза" : "Запустить";
      playButton.setAttribute(
        "aria-label",
        isPlaying ? "Пауза: остановить анимацию" : "Запустить анимацию"
      );
      playButton.setAttribute("aria-pressed", String(isPlaying));
      playButton.dataset.mode = isPlaying ? "pause" : "play";
      motionModeNote.textContent = isPlaying
        ? "Время идёт до 8 с; точка, графики и формула обновляются вместе."
        : state.t >= T_MAX
          ? "Достигнут конец интервала. Кнопка запуска начнёт движение с 0 с."
          : "При запуске время идёт до 8 с и останавливается.";
    };

    const updateLab = (changed: InputName, options: { fromPlayback?: boolean } = {}) => {
      state = normalizeState(state);
      syncInputs();
      const x = uniformPosition(state.x0, state.v, state.t);
      const delta = state.v * state.t;
      const direction = getUniformMotionDirection(state.v);

      lab.dataset.currentTime = formatPhysicsNumber(state.t, 2);
      lab.dataset.currentX = formatPhysicsNumber(x, 2);
      lab.dataset.motionDirection = direction;

      outputs.x0.value = `${formatPhysicsNumber(state.x0)} м`;
      outputs.v.value = `${formatPhysicsNumber(state.v)} м/с`;
      outputs.t.value = `${formatPhysicsNumber(state.t, 2)} с`;

      values.x0.textContent = `${formatPhysicsNumber(state.x0)} м`;
      values.v.textContent = `${formatPhysicsNumber(state.v)} м/с`;
      values.t.textContent = `${formatPhysicsNumber(state.t, 2)} с`;
      values.x.textContent = `${formatPhysicsNumber(x)} м`;
      values.delta.textContent = `${formatPhysicsNumber(delta)} м`;
      timeReadout.textContent = `${formatPhysicsNumber(state.t, 2)} с`;

      substitution.x0.textContent = formatPhysicsNumber(state.x0);
      substitution.v.textContent = formatPhysicsNumber(state.v);
      substitution.t.textContent = formatPhysicsNumber(state.t, 2);
      substitution.delta.textContent = `${formatPhysicsNumber(delta)} м`;
      substitution.x.textContent = `${formatPhysicsNumber(x)} м`;

      const positionSeries = generateUniformMotionSeries({
        x0: state.x0,
        v: state.v,
        tMax: T_MAX,
        step: 0.25
      });
      const velocitySeries = generateUniformVelocitySeries({
        x0: state.x0,
        v: state.v,
        tMax: T_MAX,
        step: 0.25
      });
      const currentPositionSeries = generatePartialUniformMotionSeries({
        x0: state.x0,
        v: state.v,
        t: state.t,
        tMax: T_MAX,
        step: 0.05
      });
      const currentVelocitySeries = generatePartialUniformVelocitySeries({
        x0: state.x0,
        v: state.v,
        t: state.t,
        tMax: T_MAX,
        step: 0.05
      });

      xBaseLine.setAttribute("points", toPolyline(positionSeries, (point) => point.x, X_DOMAIN));
      vBaseLine.setAttribute("points", toPolyline(velocitySeries, (point) => point.v, V_DOMAIN));
      xCurrentLine.setAttribute("points", toPolyline(currentPositionSeries, (point) => point.x, X_DOMAIN));
      vCurrentLine.setAttribute("points", toPolyline(currentVelocitySeries, (point) => point.v, V_DOMAIN));
      xCurrentLine.dataset.currentTime = formatPhysicsNumber(state.t, 2);
      vCurrentLine.dataset.currentTime = formatPhysicsNumber(state.t, 2);

      const currentX = mapPoint(state.t, x, X_DOMAIN);
      const currentV = mapPoint(state.t, state.v, V_DOMAIN);
      setSvgPoint(xPoint, currentX);
      setSvgPoint(vPoint, currentV);

      const pointPercent = clampNumber(((x - X_DOMAIN.min) / (X_DOMAIN.max - X_DOMAIN.min)) * 100, 3, 97);
      motionPoint.style.setProperty("--point-left", `${pointPercent}%`);
      motionPoint.dataset.motionLabel = getMotionLabel(direction);
      velocityArrow.style.setProperty("--point-left", `${pointPercent}%`);
      velocityArrow.style.setProperty("--velocity-width", `${getVelocityArrowWidth(state.v)}px`);
      velocityArrow.dataset.direction = direction;

      observation.textContent = getObservation(direction);
      xNote.textContent = getPositionNote(direction);
      vNote.textContent = getVelocityNote(direction);

      highlightFormula(lab, changed, options.fromPlayback === true);
      updatePlaybackControls();
    };

    (Object.entries(inputs) as Array<[InputName, HTMLInputElement]>).forEach(([name, input]) => {
      input.addEventListener("input", () => {
        setActiveScenario("");
        if (name === "t") {
          stopAnimation();
        }

        state = normalizeState({
          ...state,
          [name]: Number(input.value)
        });
        updateLab(name);
      });
    });

    playButton.addEventListener("click", () => {
      if (isReducedMotion) {
        stepForward();
        return;
      }

      if (isPlaying) {
        stopAnimation();
      } else {
        startAnimation();
      }
    });

    scenarioButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const scenario = button.dataset.scenario as ScenarioName | undefined;
        if (!scenario || !(scenario in scenarios)) {
          return;
        }
        stopAnimation();
        setActiveScenario(scenario);
        setState(scenarios[scenario], "v");
      });
    });

    resetButton.addEventListener("click", () => {
      stopAnimation();
      setActiveScenario("forward");
      setState(scenarios.forward, "x0");
      answerButtons.forEach((button) => {
        button.classList.remove("is-correct", "is-wrong");
        button.removeAttribute("aria-pressed");
      });
      feedback.textContent = "Выбери вариант, а лаборатория даст мягкую обратную связь.";
      feedback.dataset.state = "idle";
    });

    const handleReducedMotionChange = () => {
      isReducedMotion = reducedMotionQuery.matches;
      if (isReducedMotion) {
        stopAnimation();
      }
      updatePlaybackControls();
    };

    reducedMotionQuery.addEventListener("change", handleReducedMotionChange);

    answerButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const correct = button.dataset.answer === "correct";

        answerButtons.forEach((item) => {
          item.classList.remove("is-correct", "is-wrong");
          item.setAttribute("aria-pressed", "false");
        });

        button.setAttribute("aria-pressed", "true");
        button.classList.add(correct ? "is-correct" : "is-wrong");
        feedback.dataset.state = correct ? "success" : "warning";
        feedback.textContent = correct
          ? "Верно. Чем больше скорость, тем больше наклон x(t): координата меняется быстрее."
          : "Не совсем. Наклон графика x(t) показывает скорость. Если скорость больше, линия поднимается быстрее.";
      });
    });

    setState(scenarios.forward, "x0");
  });

  function normalizeState(state: LabState): LabState {
    return {
      x0: Number.isFinite(state.x0) ? state.x0 : 0,
      v: Number.isFinite(state.v) ? state.v : 0,
      t: normalizeUniformMotionTime(state.t, T_MAX)
    };
  }

  function toPolyline<TPoint extends { t: number }>(
    series: TPoint[],
    valueSelector: (point: TPoint) => number,
    domain: Domain
  ): string {
    return series
      .map((point) => {
        const mapped = mapPoint(point.t, valueSelector(point), domain);
        return `${formatPhysicsNumber(mapped.x, 1)},${formatPhysicsNumber(mapped.y, 1)}`;
      })
      .join(" ");
  }

  function mapPoint(t: number, value: number, domain: Domain): SvgPoint {
    const x = PAD.left + (t / T_MAX) * (SVG_WIDTH - PAD.left - PAD.right);
    const normalized = (value - domain.min) / (domain.max - domain.min);
    const y = SVG_HEIGHT - PAD.bottom - normalized * (SVG_HEIGHT - PAD.top - PAD.bottom);
    return { x, y: clampNumber(y, PAD.top, SVG_HEIGHT - PAD.bottom) };
  }

  function setSvgPoint(element: SVGCircleElement, point: SvgPoint): void {
    element.setAttribute("cx", formatPhysicsNumber(point.x, 1));
    element.setAttribute("cy", formatPhysicsNumber(point.y, 1));
  }

  function drawGrid(group: SVGGElement | null, min: number, max: number): void {
    if (!group) return;

    const lines = [];
    for (let i = 0; i <= 4; i += 1) {
      const x = PAD.left + (i / 4) * (SVG_WIDTH - PAD.left - PAD.right);
      const y = PAD.top + (i / 4) * (SVG_HEIGHT - PAD.top - PAD.bottom);
      lines.push(`<line class="grid-line" x1="${x}" y1="${PAD.top}" x2="${x}" y2="${SVG_HEIGHT - PAD.bottom}"></line>`);
      lines.push(`<line class="grid-line" x1="${PAD.left}" y1="${y}" x2="${SVG_WIDTH - PAD.right}" y2="${y}"></line>`);
    }
    const zeroY = mapPoint(0, 0, { min, max }).y;
    lines.push(`<line class="zero-line" x1="${PAD.left}" y1="${zeroY}" x2="${SVG_WIDTH - PAD.right}" y2="${zeroY}"></line>`);
    group.innerHTML = lines.join("");
  }

  function highlightFormula(root: ParentNode, changed: InputName, soft = false): void {
    const targets = changed === "x0"
      ? ["x0"]
      : changed === "v"
        ? ["v", "vt"]
        : ["t", "vt"];
    const activeTargets = new Set(targets);

    root.querySelectorAll<HTMLElement>("[data-formula-token], [data-formula-highlight]").forEach((token) => {
      const name = token.dataset.formulaToken ?? token.dataset.formulaHighlight ?? "";
      const active = activeTargets.has(name);
      token.classList.toggle("is-active", active);
      token.classList.toggle("is-soft-active", active && soft);
    });
  }

  function getMotionLabel(direction: ReturnType<typeof getUniformMotionDirection>): string {
    if (direction === "forward") return "вперёд";
    if (direction === "backward") return "назад";
    return "стоит";
  }

  function getObservation(direction: ReturnType<typeof getUniformMotionDirection>): string {
    if (direction === "forward") return "v > 0: координата растёт";
    if (direction === "backward") return "v < 0: координата уменьшается";
    return "v = 0: точка стоит на месте";
  }

  function getPositionNote(direction: ReturnType<typeof getUniformMotionDirection>): string {
    if (direction === "forward") {
      return "Текущая точка показывает координату в выбранный момент времени; линия идёт вверх, потому что v > 0.";
    }

    if (direction === "backward") {
      return "Текущая точка показывает координату в выбранный момент времени; линия идёт вниз, потому что v < 0.";
    }

    return "Текущая точка показывает координату в выбранный момент времени; линия горизонтальна, потому что v = 0.";
  }

  function getVelocityNote(direction: ReturnType<typeof getUniformMotionDirection>): string {
    if (direction === "still") {
      return "Текущая точка движется по времени на линии v = 0: скорость равна нулю.";
    }

    return "Текущая точка движется вправо по времени; горизонтальная линия показывает постоянную скорость.";
  }

  function getVelocityArrowWidth(v: number): number {
    if (v === 0) return 0;
    return clampNumber(24 + Math.abs(v) * 14, 0, 86);
  }

  function mustFind<TElement extends Element>(
    root: ParentNode,
    selector: string
  ): TElement {
    const element = root.querySelector<TElement>(selector);
    if (!element) {
      throw new Error(`UniformMotionLab: missing required element ${selector}`);
    }
    return element;
  }
</script>

