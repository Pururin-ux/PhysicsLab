---
import ControlDock from "./ControlDock.astro";
import InstrumentGraph from "./InstrumentGraph.astro";
import MotionTrack from "./MotionTrack.astro";
import type { GraphDomain, GraphTick } from "../../lib/physics/graphView";

const graphTimeTicks: GraphTick[] = [
  { value: 0, label: "0" },
  { value: 2, label: "2" },
  { value: 4, label: "4" },
  { value: 6, label: "6" },
  { value: 8, label: "8" }
];
const accelerationXGraphDomain: GraphDomain = { xMin: 0, xMax: 8, yMin: -32, yMax: 48 };
const accelerationVGraphDomain: GraphDomain = { xMin: 0, xMax: 8, yMin: -10, yMax: 10 };
const accelerationXTicks: GraphTick[] = [
  { value: -32, label: "-32" },
  { value: 0, label: "0" },
  { value: 24, label: "24" },
  { value: 48, label: "48" }
];
const accelerationVTicks: GraphTick[] = [
  { value: -10, label: "-10" },
  { value: 0, label: "0" },
  { value: 10, label: "10" }
];
const accelerationControlSliders = [
  {
    key: "v0",
    label: "Начальная скорость v₀",
    description: "Старт движения при t = 0.",
    value: 3,
    min: -6,
    max: 6,
    step: 0.5,
    unit: "м/с",
    dataInput: "v0",
    dataOutput: "v0",
    ariaLabel: "Начальная скорость v ноль в метрах в секунду",
    tone: "velocity"
  },
  {
    key: "a",
    label: "Ускорение a",
    description: "Как меняется v за 1 секунду.",
    value: 0.8,
    min: -3,
    max: 3,
    step: 0.2,
    unit: "м/с²",
    dataInput: "a",
    dataOutput: "a",
    ariaLabel: "Ускорение a в метрах в секунду в квадрате",
    tone: "acceleration"
  }
] as const;
---

<section
  class="acceleration-scene pl-lab-glass-panel"
  data-acceleration-scene
  data-current-time="0"
  data-current-x="0"
  data-current-v="3"
  data-current-a="0.8"
  data-motion-direction="forward"
  data-acceleration-mode="speeding-up"
  data-playing="false"
  data-animation-state="paused"
  aria-labelledby="acceleration-scene-title"
>
  <div class="scene-head">
    <div>
      <p class="component-label">прототип v0</p>
      <h3 id="acceleration-scene-title">Проверь прогноз: a меняет скорость</h3>
      <p>
        Сначала смотри на v(t): ускорение меняет скорость. Потом смотри на x(t):
        если скорость меняется, линия координаты становится кривой.
      </p>
    </div>
    <div class="scene-readouts" data-scene-readouts aria-label="Текущие значения">
      <span>t = <b data-value="t">0 с</b></span>
      <span>v = <b data-value="v">3 м/с</b></span>
      <span>x = <b data-value="x">0 м</b></span>
    </div>
  </div>

  <ControlDock
    rootClass="acceleration-controls"
    ariaLabel="Управление равноускоренным движением"
    showTimeActions
    sliders={accelerationControlSliders}
    readouts={[]}
    scenarios={[]}
    hint="Сначала меняй a. v₀ задаёт старт линии v(t), а a меняет её наклон."
  />

  <div class="scene-grid">
    <div class="motion-panel pl-motion-track" data-motion-panel aria-label="Движение точки по прямой">
      <div class="panel-head">
        <span>Тело на прямой</span>
        <strong data-observation>скорость растёт</strong>
      </div>
      <MotionTrack
        leftLabel="-32 м"
        centerLabel="0"
        rightLabel="48 м"
        initialCoordinateLabel="x = 0 м"
      />
      <p data-guidance>
        Сейчас a положительное: скорость растёт, поэтому точка разгоняется вправо.
      </p>
      <div class="motion-causality-strip" aria-label="Связь ускорения, скорости и координаты">
        <span data-variable="a"><b>a</b> меняет v(t)</span>
        <span data-variable="v"><b>v</b> двигает точку</span>
        <span data-variable="x"><b>x</b> попадает на x(t)</span>
      </div>
    </div>

    <div class="graph-stack" data-graph-stack>
      <InstrumentGraph
        title="График v(t)"
        graphKind="v"
        xAxisLabel="t, с"
        yAxisLabel="v, м/с"
        ariaLabel="График скорости от времени при равноускоренном движении"
        note="Наклон v(t) показывает ускорение: если a не равно нулю, скорость меняется."
        domain={accelerationVGraphDomain}
        xTicks={graphTimeTicks}
        yTicks={accelerationVTicks}
        showTickLabels
      />
      <InstrumentGraph
        title="График x(t)"
        graphKind="x"
        xAxisLabel="t, с"
        yAxisLabel="x, м"
        ariaLabel="График координаты от времени при равноускоренном движении"
        note="x(t) становится кривой: её наклон меняется вместе со скоростью."
        domain={accelerationXGraphDomain}
        xTicks={graphTimeTicks}
        yTicks={accelerationXTicks}
        showTickLabels
      />
    </div>
  </div>

</section>

<script>
  import {
    accelerationMotionDirection,
    generatePositionSeries,
    generateVelocitySeries,
    positionAt,
    velocityAt
  } from "../../lib/physics/acceleratedMotion";
  import {
    clampNumber,
    formatPhysicsNumber,
    normalizeUniformMotionTime
  } from "../../lib/physics/kinematics";
  import { mapToGraphPoint, seriesToPolyline } from "../../lib/physics/graphView";
  import type { GraphDomain, GraphPoint } from "../../lib/physics/graphView";

  type SceneState = { x0: number; v0: number; a: number; t: number };
  type Domain = { min: number; max: number };
  type Direction = ReturnType<typeof accelerationMotionDirection>;

  const T_MAX = 8;
  const X_DOMAIN: Domain = { min: -32, max: 48 };
  const V_DOMAIN: Domain = { min: -10, max: 10 };
  const X_GRAPH_DOMAIN: GraphDomain = { xMin: 0, xMax: T_MAX, yMin: X_DOMAIN.min, yMax: X_DOMAIN.max };
  const V_GRAPH_DOMAIN: GraphDomain = { xMin: 0, xMax: T_MAX, yMin: V_DOMAIN.min, yMax: V_DOMAIN.max };
  const PLAYBACK_RATE = 1;
  const REDUCED_MOTION_STEP = 0.5;

  document.querySelectorAll<HTMLElement>("[data-acceleration-scene]").forEach((scene) => {
    const inputs = {
      v0: mustFind<HTMLInputElement>(scene, '[data-input="v0"]'),
      a: mustFind<HTMLInputElement>(scene, '[data-input="a"]')
    };

    const outputs = {
      v0: mustFind<HTMLOutputElement>(scene, '[data-output="v0"]'),
      a: mustFind<HTMLOutputElement>(scene, '[data-output="a"]')
    };

    const values = {
      t: mustFind<HTMLElement>(scene, '[data-value="t"]'),
      v: mustFind<HTMLElement>(scene, '[data-value="v"]'),
      x: mustFind<HTMLElement>(scene, '[data-value="x"]')
    };

    const xBaseLine = mustFind<SVGPolylineElement>(scene, '[data-polyline="x"]');
    const vBaseLine = mustFind<SVGPolylineElement>(scene, '[data-polyline="v"]');
    const xCurrentLine = mustFind<SVGPolylineElement>(scene, '[data-current-polyline="x"]');
    const vCurrentLine = mustFind<SVGPolylineElement>(scene, '[data-current-polyline="v"]');
    const xPoint = mustFind<SVGCircleElement>(scene, '[data-point="x"]');
    const vPoint = mustFind<SVGCircleElement>(scene, '[data-point="v"]');
    const motionPoint = mustFind<HTMLElement>(scene, "[data-motion-point]");
    const velocityArrow = mustFind<HTMLElement>(scene, "[data-velocity-arrow]");
    const motionXLabel = mustFind<HTMLElement>(scene, "[data-motion-x-label]");
    const observation = mustFind<HTMLElement>(scene, "[data-observation]");
    const guidance = mustFind<HTMLElement>(scene, "[data-guidance]");
    const xNote = mustFind<HTMLElement>(scene, '[data-graph-note="x"]');
    const vNote = mustFind<HTMLElement>(scene, '[data-graph-note="v"]');
    const playButton = mustFind<HTMLButtonElement>(scene, "[data-play-toggle]");
    const resetButton = mustFind<HTMLButtonElement>(scene, "[data-reset]");
    const reducedMotionQuery = window.matchMedia("(prefers-reduced-motion: reduce)");

    let state: SceneState = { x0: 0, v0: 3, a: 0.8, t: 0 };
    let isPlaying = false;
    let isReducedMotion = reducedMotionQuery.matches;
    let animationFrameId: number | null = null;
    let previousFrameTime: number | null = null;

    const syncInputs = () => {
      inputs.v0.value = formatPhysicsNumber(state.v0);
      inputs.a.value = formatPhysicsNumber(state.a);
    };

    const setState = (nextState: SceneState) => {
      state = normalizeState(nextState);
      updateScene();
    };

    const stopAnimation = () => {
      if (animationFrameId !== null) {
        window.cancelAnimationFrame(animationFrameId);
        animationFrameId = null;
      }

      previousFrameTime = null;
      isPlaying = false;
      updatePlaybackControls();
    };

    const stepForward = () => {
      stopAnimation();
      state = normalizeState({
        ...state,
        t: state.t >= T_MAX
          ? 0
          : normalizeUniformMotionTime(state.t + REDUCED_MOTION_STEP, T_MAX)
      });
      updateScene();
    };

    const startAnimation = () => {
      if (isReducedMotion) {
        stepForward();
        return;
      }

      if (state.t >= T_MAX) {
        state = normalizeState({ ...state, t: 0 });
      }

      isPlaying = true;
      previousFrameTime = null;
      updateScene();
      animationFrameId = window.requestAnimationFrame(tickAnimation);
    };

    const tickAnimation = (timestamp: number) => {
      if (!isPlaying) return;

      if (previousFrameTime === null) {
        previousFrameTime = timestamp;
      }

      const deltaSeconds = ((timestamp - previousFrameTime) / 1000) * PLAYBACK_RATE;
      previousFrameTime = timestamp;
      const nextT = normalizeUniformMotionTime(state.t + deltaSeconds, T_MAX);
      state = normalizeState({ ...state, t: nextT });
      updateScene();

      if (nextT >= T_MAX) {
        stopAnimation();
        return;
      }

      animationFrameId = window.requestAnimationFrame(tickAnimation);
    };

    const updatePlaybackControls = () => {
      scene.dataset.playing = String(isPlaying);
      scene.dataset.animationState = isPlaying ? "running" : "paused";

      if (isReducedMotion) {
        playButton.textContent = "Шаг вперёд";
        playButton.setAttribute("aria-label", "Шаг вперёд по времени");
        playButton.setAttribute("aria-pressed", "false");
        playButton.dataset.mode = "step";
        return;
      }

      playButton.textContent = isPlaying ? "Пауза" : "Запустить";
      playButton.setAttribute(
        "aria-label",
        isPlaying ? "Пауза: остановить анимацию" : "Запустить анимацию"
      );
      playButton.setAttribute("aria-pressed", String(isPlaying));
      playButton.dataset.mode = isPlaying ? "pause" : "play";
    };

    const updateScene = () => {
      state = normalizeState(state);
      syncInputs();
      const x = positionAt(state.t, state.x0, state.v0, state.a);
      const v = velocityAt(state.t, state.v0, state.a);
      const direction = accelerationMotionDirection(state.t, state.v0, state.a);
      const mode = getAccelerationMode(state, v);

      scene.dataset.currentTime = formatPhysicsNumber(state.t, 2);
      scene.dataset.currentX = formatPhysicsNumber(x, 2);
      scene.dataset.currentV = formatPhysicsNumber(v, 2);
      scene.dataset.currentA = formatPhysicsNumber(state.a, 2);
      scene.dataset.motionDirection = direction;
      scene.dataset.accelerationMode = mode;

      outputs.v0.textContent = `${formatPhysicsNumber(state.v0)} м/с`;
      outputs.a.textContent = `${formatPhysicsNumber(state.a)} м/с²`;
      values.t.textContent = `${formatPhysicsNumber(state.t, 2)} с`;
      values.v.textContent = `${formatPhysicsNumber(v, 2)} м/с`;
      values.x.textContent = `${formatPhysicsNumber(x, 2)} м`;

      xBaseLine.setAttribute(
        "points",
        seriesToPolyline(generatePositionSeries({ ...state, tMax: T_MAX }), (point) =>
          mapToGraphPoint(point.t, point.x, X_GRAPH_DOMAIN)
        )
      );
      xCurrentLine.setAttribute(
        "points",
        seriesToPolyline(generatePositionSeries({ ...state, tMax: state.t }), (point) =>
          mapToGraphPoint(point.t, point.x, X_GRAPH_DOMAIN)
        )
      );
      vBaseLine.setAttribute(
        "points",
        seriesToPolyline(generateVelocitySeries({ v0: state.v0, a: state.a, tMax: T_MAX }), (point) =>
          mapToGraphPoint(point.t, point.v, V_GRAPH_DOMAIN)
        )
      );
      vCurrentLine.setAttribute(
        "points",
        seriesToPolyline(generateVelocitySeries({ v0: state.v0, a: state.a, tMax: state.t }), (point) =>
          mapToGraphPoint(point.t, point.v, V_GRAPH_DOMAIN)
        )
      );

      const xGraphPoint = mapToGraphPoint(state.t, x, X_GRAPH_DOMAIN);
      const vGraphPoint = mapToGraphPoint(state.t, v, V_GRAPH_DOMAIN);
      setCirclePoint(xPoint, xGraphPoint);
      setCirclePoint(vPoint, vGraphPoint);

      const motionPercent = mapPercent(x, X_DOMAIN);
      motionPoint.style.setProperty("--point-left", `${motionPercent}%`);
      motionPoint.dataset.motionLabel = `v = ${formatPhysicsNumber(v, 1)} м/с`;
      motionXLabel.style.setProperty("--point-left", `${motionPercent}%`);
      motionXLabel.textContent = `x = ${formatPhysicsNumber(x, 1)} м`;
      velocityArrow.style.setProperty("--point-left", `${motionPercent}%`);
      velocityArrow.style.setProperty("--velocity-width", `${getVelocityArrowWidth(v)}px`);
      velocityArrow.dataset.direction = direction;

      observation.textContent = getObservation(mode, direction);
      guidance.textContent = getGuidance(mode, direction);
      xNote.textContent = getPositionNote(state.a);
      vNote.textContent = getVelocityNote(state.a);
      updatePlaybackControls();
    };

    playButton.addEventListener("click", () => {
      if (isPlaying) {
        stopAnimation();
      } else {
        startAnimation();
      }
    });

    resetButton.addEventListener("click", () => {
      stopAnimation();
      setState({ x0: 0, v0: 3, a: 0.8, t: 0 });
    });

    inputs.v0.addEventListener("input", () => {
      stopAnimation();
      setState({ ...state, v0: Number(inputs.v0.value), t: 0 });
    });

    inputs.a.addEventListener("input", () => {
      stopAnimation();
      setState({ ...state, a: Number(inputs.a.value) });
    });

    reducedMotionQuery.addEventListener("change", (event) => {
      isReducedMotion = event.matches;
      stopAnimation();
      updatePlaybackControls();
    });

    updateScene();
  });

  function normalizeState(state: SceneState): SceneState {
    return {
      x0: 0,
      v0: clampNumber(state.v0, -6, 6),
      a: clampNumber(state.a, -3, 3),
      t: normalizeUniformMotionTime(state.t, T_MAX)
    };
  }

  function mapPercent(value: number, domain: Domain): number {
    return clampNumber(((value - domain.min) / (domain.max - domain.min)) * 100, 5, 95);
  }

  function setCirclePoint(circle: SVGCircleElement, point: GraphPoint) {
    circle.setAttribute("cx", formatPhysicsNumber(point.x, 2));
    circle.setAttribute("cy", formatPhysicsNumber(point.y, 2));
  }

  function getAccelerationMode(state: SceneState, v: number): string {
    if (state.a === 0) return "uniform";
    if (Math.abs(v) < 1e-9) return "turning-point";
    if (state.v0 > 0 && state.a < 0 && v > 0) return "slowing-forward";
    if (state.v0 < 0 && state.a > 0 && v < 0) return "slowing-backward";
    if (v > 0) return "speeding-up";
    return "moving-backward";
  }

  function getObservation(mode: string, direction: Direction): string {
    if (mode === "uniform") return "как равномерное";
    if (mode === "turning-point") return "почти остановка";
    if (mode === "slowing-forward") return "ещё вправо";
    if (mode === "slowing-backward") return "ещё назад";
    if (direction === "backward") return "едет назад";
    return "скорость растёт";
  }

  function getGuidance(mode: string, direction: Direction): string {
    if (mode === "uniform") {
      return "a = 0: скорость не меняется. Это снова равномерное движение.";
    }

    if (mode === "slowing-forward") {
      return "a отрицательное, но тело ещё едет вправо: скорость уменьшается, а не направление сразу меняется.";
    }

    if (mode === "slowing-backward") {
      return "a положительное, но тело ещё едет назад: скорость по модулю уменьшается.";
    }

    if (mode === "turning-point") {
      return "В этот момент скорость стала почти нулевой. После этого направление может измениться.";
    }

    if (direction === "backward") {
      return "Скорость стала отрицательной: теперь точка действительно едет назад.";
    }

    return "a положительное: скорость растёт, поэтому точка разгоняется вправо.";
  }

  function getPositionNote(a: number): string {
    if (a === 0) {
      return "При a = 0 скорость постоянная, поэтому x(t) снова прямая.";
    }

    return "x(t) кривая: её наклон всё время меняется, потому что меняется скорость.";
  }

  function getVelocityNote(a: number): string {
    if (a === 0) {
      return "a = 0: v(t) горизонтальная. Скорость постоянная, значит движение снова равномерное.";
    }

    return a > 0
      ? "a > 0: v(t) идёт вверх. Наклон этой линии и есть ускорение."
      : "a < 0: v(t) идёт вниз. Это уменьшает скорость, но назад тело поедет только когда v станет меньше нуля.";
  }

  function getVelocityArrowWidth(v: number): number {
    if (Math.abs(v) < 1e-9) return 0;
    return clampNumber(24 + Math.abs(v) * 8, 0, 96);
  }

  function mustFind<TElement extends Element>(
    root: ParentNode,
    selector: string
  ): TElement {
    const element = root.querySelector<TElement>(selector);
    if (!element) {
      throw new Error(`AccelerationScene: missing required element ${selector}`);
    }

    return element;
  }
</script>

<style>
  .acceleration-scene {
    display: grid;
    gap: clamp(var(--pl-space-3), 1.35vw, var(--pl-space-4));
    padding: clamp(var(--pl-space-3), 1.7vw, var(--pl-space-5));
    border-color: rgba(88, 216, 255, 0.2);
    border-radius: 24px;
    background:
      radial-gradient(ellipse at 48% -12%, rgba(88, 216, 255, 0.1), transparent 34rem),
      radial-gradient(ellipse at 80% 16%, rgba(255, 216, 77, 0.07), transparent 28rem),
      rgba(4, 12, 24, 0.86);
  }

  .scene-head {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(220px, 0.4fr);
    gap: var(--pl-space-3);
    align-items: center;
  }

  .component-label {
    display: inline-flex;
    min-height: 24px;
    margin: 0 0 var(--pl-space-1);
    padding: 3px 9px;
    border: 1px solid rgba(255, 216, 77, 0.24);
    border-radius: 999px;
    color: var(--pl-accent);
    background: rgba(255, 216, 77, 0.055);
    font-size: 0.72rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  .scene-head h3 {
    margin-bottom: var(--pl-space-1);
    font-size: 1.55rem;
  }

  .scene-head p {
    max-width: 720px;
    margin: 0;
    line-height: 1.45;
  }

  .scene-readouts {
    display: grid;
    gap: var(--pl-space-1);
  }

  .scene-readouts span {
    padding: 6px 10px;
    border: 1px solid rgba(88, 216, 255, 0.14);
    border-radius: 999px;
    color: var(--pl-text-muted);
    background: rgba(255, 255, 255, 0.032);
    font-size: 0.92rem;
    line-height: 1.2;
  }

  .scene-readouts b {
    color: var(--pl-accent);
  }

  .scene-grid {
    display: grid;
    grid-template-columns: minmax(300px, 0.94fr) minmax(360px, 1.06fr);
    gap: var(--pl-space-3);
    align-items: start;
  }

  .motion-panel {
    display: grid;
    gap: var(--pl-space-2);
    min-width: 0;
    padding: var(--pl-space-3);
    border-radius: 18px;
    background:
      radial-gradient(ellipse at 50% 14%, rgba(88, 216, 255, 0.11), transparent 22rem),
      rgba(4, 13, 26, 0.78);
  }

  .panel-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: var(--pl-space-3);
    color: var(--pl-text);
    font-weight: 900;
  }

  .panel-head strong {
    color: var(--pl-accent);
    text-align: right;
  }

  .motion-panel p,
  .formula-card p,
  .chapter-feedback {
    margin: 0;
    line-height: 1.45;
  }

  .graph-stack {
    display: grid;
    gap: var(--pl-space-3);
    min-width: 0;
  }

  :global(.acceleration-scene .track) {
    min-height: clamp(190px, 18vw, 240px);
    margin-block: var(--pl-space-1);
  }

  :global(.acceleration-scene .track::before) {
    bottom: 72px;
  }

  :global(.acceleration-scene .track-axis) {
    bottom: 72px;
  }

  :global(.acceleration-scene .track-tick) {
    bottom: 62px;
  }

  :global(.acceleration-scene .motion-point) {
    bottom: 87px;
  }

  :global(.acceleration-scene .motion-x-label) {
    bottom: 132px;
  }

  :global(.acceleration-scene .velocity-arrow) {
    bottom: 103px;
  }

  .motion-causality-strip {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--pl-space-2);
    margin-top: var(--pl-space-1);
  }

  .motion-causality-strip span {
    min-width: 0;
    min-height: 38px;
    padding: 6px 8px;
    border: 1px solid rgba(88, 216, 255, 0.1);
    border-radius: 14px;
    color: var(--pl-text-muted);
    background: rgba(255, 255, 255, 0.024);
    font-size: 0.84rem;
    line-height: 1.25;
  }

  .motion-causality-strip b {
    display: block;
    margin-bottom: 2px;
    font-family: "Cascadia Mono", "JetBrains Mono", Consolas, monospace;
    font-size: 0.98rem;
  }

  :global(.acceleration-scene .graph-card) {
    padding: var(--pl-space-3);
    border-radius: 14px;
  }

  :global(.acceleration-scene .graph-card figcaption) {
    margin-bottom: var(--pl-space-1);
    font-size: 1rem;
  }

  :global(.acceleration-scene .graph-card svg) {
    min-height: 220px;
    margin-bottom: var(--pl-space-2);
