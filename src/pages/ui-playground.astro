---
import BaseLayout from "../layouts/BaseLayout.astro";
import MathFormula from "../components/math/MathFormula.astro";
import FormulaCardExperiment from "../components/playground/FormulaCardExperiment.astro";

type PlaygroundZone = {
  id: string;
  key: string;
  title: string;
  label: string;
  description: string;
  emptyText: string;
  checks: string[];
};

const navItems = [
  { href: "#formulas", label: "Формулы" },
  { href: "#mascot", label: "Маскот" },
  { href: "#motion-feedback", label: "Движение" }
];

const zones: PlaygroundZone[] = [
  {
    id: "formulas",
    key: "FormulaCard experiments",
    title: "Формулы",
    label: "карточки формул",
    description: "Здесь будут проверяться варианты карточек формул, подстановок и подсветки переменных.",
    emptyText: "Пока пусто. Первый прототип попадет сюда только после отдельного анализа сэмпла.",
    checks: ["русский текст", "mobile 360 px", "без лишних чисел"]
  },
  {
    id: "mascot",
    key: "MascotBubble experiments",
    title: "Маскот",
    label: "реплики и окна",
    description: "Зона для будущих реплик и всплывающих окон без подключения реальных ассетов маскота.",
    emptyText: "Пока здесь только безопасная заглушка. Реальные изображения не подключены.",
    checks: ["не конкурирует с графиком", "короткая реплика", "без финальных ассетов"]
  },
  {
    id: "motion-feedback",
    key: "Motion/Feedback experiments",
    title: "Движение и обратная связь",
    label: "движение и обратная связь",
    description: "Место для спокойных состояний обратной связи, раскрытий и проверки движения с уменьшенной анимацией.",
    emptyText: "Пока пусто. Любая анимация сначала должна объяснять действие, а не украшать экран.",
    checks: ["уменьшенная анимация", "нет мигания", "смысл рядом с действием"]
  }
];
---

<BaseLayout
  title="PhysicsLab - песочница интерфейса"
  description="Безопасная страница для экспериментов с интерфейсом PhysicsLab без изменения lab-preview."
  navItems={navItems}
>
  <canvas class="playground-particles" data-playground-particles aria-hidden="true"></canvas>

  <section class="section playground-hero" aria-labelledby="playground-title">
    <div class="playground-hero__copy">
      <h1 id="playground-title">Песочница интерфейса PhysicsLab</h1>
      <p class="playground-lead">
        Здесь можно проверять будущие сгенерированные компоненты перед переносом в основной интерфейс.
        Эта страница изолирована и не меняет демо-лабораторию.
      </p>

      <nav class="quick-links" aria-label="Быстрые ссылки песочницы">
        <a href="#formulas">Формулы</a>
        <a href="#mascot">Маскот</a>
        <a href="#motion-feedback">Движение</a>
      </nav>
    </div>

    <aside class="playground-note" aria-label="Правила песочницы">
      <strong>Правило страницы</strong>
      <p>
        Сначала прототип и скриншоты, потом решение о переносе. Реальные ассеты маскота,
        новые зависимости и изменения `/lab-preview/` сюда не входят.
      </p>
    </aside>
  </section>

  <section class="section playground-zones" aria-labelledby="zones-title">
    <div class="zones-heading">
      <h2 id="zones-title">Три места для будущих прототипов</h2>
      <p>
        Сейчас здесь только каркас. Он нужен, чтобы сгенерированный интерфейс можно было тестировать
        отдельно от учебной страницы и фиксировать скриншоты по размерам экрана.
      </p>
    </div>

    <div class="zone-grid" aria-label="Зоны UI-песочницы">
      {
        zones.map((zone, index) => (
          <article
            id={zone.id}
            class:list={[
              "experiment-zone",
              zone.id === "formulas" ? "experiment-zone--prototype" : ""
            ]}
            data-experiment-zone={zone.key}
            aria-labelledby={`${zone.id}-title`}
          >
            <div class="zone-kicker">
              <span aria-hidden="true">{String(index + 1).padStart(2, "0")}</span>
              <small>{zone.label}</small>
            </div>
            <h3 id={`${zone.id}-title`}>{zone.title}</h3>
            <p>{zone.description}</p>

            {
              zone.id === "formulas" ? (
                <div class="formula-playground-stack">
                  <FormulaCardExperiment />

                  <section class="katex-check" data-katex-check aria-labelledby="katex-check-title">
                    <div class="katex-check__intro">
                      <p class="katex-check__label">KaTeX-проверка</p>
                      <h4 id="katex-check-title">Формулы без ручной верстки</h4>
                      <p>
                        Этот блок проверяет индексы, степени и дроби. Интерактивные формулы
                        можно оставлять кастомными, а обычные учебные формулы отдавать KaTeX.
                      </p>
                    </div>

                    <div class="katex-check__grid" aria-label="Примеры формул KaTeX">
                      <article class="katex-check__item">
                        <span>Равномерное движение</span>
                        <MathFormula tex="x = x_0 + vt" display />
                      </article>
                      <article class="katex-check__item">
                        <span>Скорость при ускорении</span>
                        <MathFormula tex="v = v_0 + at" display />
                      </article>
                      <article class="katex-check__item">
                        <span>Путь при ускорении</span>
                        <MathFormula tex={"s = v_0 t + \\frac{a t^2}{2}"} display />
                      </article>
                    </div>
                  </section>
                </div>
              ) : (
                <div class="empty-slot" aria-label={`Пустая зона: ${zone.title}`}>
                  <span class="slot-mark" aria-hidden="true">+</span>
                  <strong>{zone.emptyText}</strong>
                </div>
              )
            }

            <ul class="check-list" aria-label={`Что проверять: ${zone.title}`}>
              {zone.checks.map((check) => <li>{check}</li>)}
            </ul>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>

<style>
  .playground-particles {
    position: fixed;
    inset: 0;
    z-index: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    opacity: 0.38;
  }

  .playground-hero,
  .playground-zones {
    position: relative;
    z-index: 1;
  }

  .playground-hero {
    display: grid;
    grid-template-columns: minmax(0, 0.9fr) minmax(240px, 0.34fr);
    gap: var(--pl-space-4);
    align-items: start;
    padding-top: var(--pl-space-5);
    padding-bottom: var(--pl-space-3);
  }

  .playground-hero__copy {
    max-width: 820px;
  }

  .playground-hero h1 {
    max-width: 620px;
    margin-bottom: var(--pl-space-2);
    font-size: clamp(1.9rem, 3.8vw, 3.35rem);
  }

  .playground-lead {
    max-width: 600px;
    margin-bottom: 0;
    font-size: clamp(0.96rem, 1.2vw, 1.04rem);
    line-height: 1.48;
  }

  .quick-links {
    display: flex;
    flex-wrap: wrap;
    gap: var(--pl-space-2);
    margin-top: var(--pl-space-3);
  }

  .quick-links a {
    display: inline-flex;
    align-items: center;
    min-height: 34px;
    padding: 7px 11px;
    border: 1px solid rgba(88, 216, 255, 0.22);
    border-radius: 999px;
    color: var(--pl-text);
    background: rgba(8, 14, 24, 0.66);
    font-size: 0.9rem;
    font-weight: 800;
    line-height: 1.2;
    text-decoration: none;
  }

  .quick-links a:hover {
    border-color: rgba(255, 216, 77, 0.45);
    color: var(--pl-accent);
  }

  .playground-note {
    min-width: 0;
    padding: var(--pl-space-3);
    border: 1px solid rgba(255, 216, 77, 0.26);
    border-radius: var(--pl-radius);
    background:
      linear-gradient(135deg, rgba(255, 216, 77, 0.08), transparent 52%),
      rgba(16, 23, 34, 0.78);
  }

  .playground-note strong {
    display: block;
    margin-bottom: var(--pl-space-2);
    color: var(--pl-accent);
  }

  .playground-note p {
    margin-bottom: 0;
    font-size: 0.9rem;
    line-height: 1.45;
  }

  .playground-zones {
    padding-top: 0;
  }

  .zones-heading {
    display: grid;
    grid-template-columns: minmax(260px, 0.4fr) minmax(0, 0.6fr);
    gap: var(--pl-space-3);
    align-items: end;
    max-width: 980px;
    margin-bottom: var(--pl-space-2);
  }

  .zones-heading h2 {
    margin-bottom: 0;
    font-size: clamp(1.35rem, 2.3vw, 2.05rem);
  }

  .zones-heading p:last-child {
    margin-bottom: 0;
    font-size: 0.9rem;
    line-height: 1.42;
  }

  .zone-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--pl-space-5);
  }

  .experiment-zone {
    display: grid;
    gap: var(--pl-space-4);
    min-width: 0;
    padding: var(--pl-space-5);
    border: 1px solid var(--pl-border-soft);
    border-radius: var(--pl-radius);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.035), transparent 64%),
      var(--pl-surface-quiet);
    box-shadow: var(--pl-shadow-soft);
  }

  .experiment-zone--prototype {
    grid-column: 1 / -1;
    gap: var(--pl-space-2);
    padding: 0;
    border: 0;
    background: transparent;
    box-shadow: none;
  }

  .experiment-zone--prototype .zone-kicker {
    display: none;
  }

  .experiment-zone--prototype h3 {
    margin-bottom: 0;
    font-size: clamp(1.08rem, 1.6vw, 1.28rem);
  }

  .experiment-zone--prototype > p {
    max-width: 780px;
    font-size: 0.9rem;
    line-height: 1.42;
  }

  .experiment-zone:nth-child(2) {
    border-color: rgba(181, 156, 255, 0.28);
  }

  .experiment-zone:nth-child(3) {
    border-color: rgba(88, 216, 255, 0.24);
  }

  .zone-kicker {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--pl-space-3);
    min-width: 0;
  }

  .zone-kicker span {
    display: inline-grid;
    place-items: center;
    width: 42px;
    height: 34px;
    border: 1px solid rgba(255, 216, 77, 0.62);
    border-radius: var(--pl-radius-sm);
    color: #111317;
    background: var(--pl-accent);
    font-size: 0.86rem;
    font-weight: 950;
  }

  .zone-kicker small {
    min-width: 0;
    color: var(--pl-text-soft);
    font-size: 0.78rem;
    font-weight: 850;
    text-align: right;
    overflow-wrap: anywhere;
  }

  .experiment-zone h3 {
    margin-bottom: 0;
  }

  .experiment-zone p {
    margin-bottom: 0;
  }

  .formula-playground-stack {
    display: grid;
    gap: var(--pl-space-5);
    min-width: 0;
  }

  .katex-check {
    display: grid;
    grid-template-columns: minmax(220px, 0.34fr) minmax(0, 1fr);
    gap: var(--pl-space-4);
    min-width: 0;
    padding: clamp(var(--pl-space-4), 2.5vw, var(--pl-space-6));
    overflow: hidden;
    border: 1px solid rgba(88, 216, 255, 0.24);
    border-radius: var(--pl-radius);
    background:
      linear-gradient(135deg, rgba(88, 216, 255, 0.08), transparent 44%),
      rgba(8, 13, 22, 0.88);
  }

  .katex-check__intro {
    min-width: 0;
  }

  .katex-check__label {
    margin: 0 0 var(--pl-space-2);
    color: var(--pl-accent);
    font-size: 0.78rem;
    font-weight: 900;
    line-height: 1.3;
    text-transform: uppercase;
  }

  .katex-check h4 {
    margin: 0 0 var(--pl-space-3);
    color: var(--pl-text);
    font-size: clamp(1.18rem, 2vw, 1.55rem);
    line-height: 1.15;
  }

  .katex-check__intro p:last-child {
    color: var(--pl-text-muted);
    font-size: 0.96rem;
    line-height: 1.55;
  }

  .katex-check__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--pl-space-3);
    min-width: 0;
  }

  .katex-check__item {
    display: grid;
    align-content: center;
    gap: var(--pl-space-3);
    min-width: 0;
    padding: var(--pl-space-4);
    border: 1px solid rgba(88, 216, 255, 0.18);
    border-radius: var(--pl-radius);
    background:
      linear-gradient(rgba(88, 216, 255, 0.035) 1px, transparent 1px),
      linear-gradient(90deg, rgba(88, 216, 255, 0.035) 1px, transparent 1px),
      rgba(10, 17, 28, 0.72);
    background-size: 24px 24px;
  }

  .katex-check__item span {
    color: var(--pl-text-soft);
    font-size: 0.84rem;
    font-weight: 850;
    line-height: 1.35;
  }

  .empty-slot {
    display: grid;
    place-items: center;
    gap: var(--pl-space-3);
    min-height: 180px;
    padding: var(--pl-space-4);
    border: 1px dashed rgba(168, 190, 213, 0.34);
    border-radius: var(--pl-radius);
    color: var(--pl-text-muted);
    background:
      linear-gradient(rgba(88, 216, 255, 0.035) 1px, transparent 1px),
      linear-gradient(90deg, rgba(88, 216, 255, 0.035) 1px, transparent 1px),
      rgba(8, 12, 18, 0.48);
    background-size: 28px 28px;
    text-align: center;
  }

  .slot-mark {
    display: grid;
    place-items: center;
    width: 44px;
    height: 44px;
    border: 1px solid rgba(88, 216, 255, 0.4);
    border-radius: 50%;
    color: var(--pl-cyan);
    font-size: 1.5rem;
    font-weight: 900;
    line-height: 1;
  }

  .empty-slot strong {
    max-width: 28ch;
    color: var(--pl-text);
    font-size: 0.98rem;
    line-height: 1.5;
  }

  .check-list {
    display: flex;
    flex-wrap: wrap;
    gap: var(--pl-space-2);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .check-list li {
    min-width: 0;
    padding: 7px 9px;
    border: 1px solid var(--pl-border-soft);
    border-radius: 999px;
    color: var(--pl-text-muted);
    background: rgba(255, 255, 255, 0.035);
    font-size: 0.86rem;
    line-height: 1.3;
  }

  @media (max-width: 980px) {
    .playground-hero,
    .zones-heading,
    .zone-grid,
    .katex-check {
      grid-template-columns: 1fr;
    }

    .playground-note {
      max-width: 720px;
    }
  }

  @media (max-width: 600px) {
    .playground-hero {
      gap: var(--pl-space-3);
      padding-top: var(--pl-space-3);
      padding-bottom: var(--pl-space-3);
    }

    .playground-hero h1 {
      font-size: clamp(1.75rem, 8.8vw, 2.35rem);
    }

    .quick-links a {
      min-height: 32px;
      padding: 6px 10px;
      font-size: 0.84rem;
    }

    .playground-note,
    .zones-heading {
      display: none;
    }

    .playground-zones {
      padding-top: 0;
    }

    .experiment-zone {
      padding: var(--pl-space-4);
    }

    .zone-kicker {
      align-items: flex-start;
      flex-direction: column;
    }

    .zone-kicker small {
      text-align: left;
    }

    .empty-slot {
      min-height: 150px;
    }

    .katex-check__grid {
      grid-template-columns: 1fr;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .playground-particles {
      opacity: 0.18;
    }
  }
</style>

<script>
  const particleCanvas = document.querySelector<HTMLCanvasElement>("[data-playground-particles]");
  const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (particleCanvas) {
    const context = particleCanvas.getContext("2d");

    type Particle = {
      x: number;
      y: number;
      vx: number;
      vy: number;
      radius: number;
      opacity: number;
      accent: boolean;
    };

    let width = 0;
    let height = 0;
    let particles: Particle[] = [];
    let animationFrame = 0;

    const resizeCanvas = () => {
      const scale = Math.min(window.devicePixelRatio || 1, 2);
      width = window.innerWidth;
      height = window.innerHeight;
      particleCanvas.width = Math.floor(width * scale);
      particleCanvas.height = Math.floor(height * scale);
      particleCanvas.style.width = `${width}px`;
      particleCanvas.style.height = `${height}px`;
      context?.setTransform(scale, 0, 0, scale, 0, 0);

      const count = Math.max(26, Math.min(58, Math.round((width * height) / 26000)));
      particles = Array.from({ length: count }, (_, index) => ({
        x: Math.random() * width,
        y: Math.random() * height,
        vx: (Math.random() - 0.5) * 0.18,
        vy: (Math.random() - 0.5) * 0.18,
        radius: Math.random() * 1.15 + 0.45,
        opacity: Math.random() * 0.28 + 0.14,
        accent: index < 5
      }));
    };

    const drawParticles = () => {
      if (!context) return;

      context.clearRect(0, 0, width, height);

      particles.forEach((particle, index) => {
        if (!reducedMotion) {
          particle.x += particle.vx;
          particle.y += particle.vy;

          if (particle.x < -8) particle.x = width + 8;
          if (particle.x > width + 8) particle.x = -8;
          if (particle.y < -8) particle.y = height + 8;
          if (particle.y > height + 8) particle.y = -8;
        }

        context.beginPath();
        context.arc(particle.x, particle.y, particle.radius, 0, Math.PI * 2);
        context.fillStyle = particle.accent
          ? `rgba(255, 216, 77, ${particle.opacity})`
          : `rgba(88, 216, 255, ${particle.opacity})`;
        context.fill();

        for (let nextIndex = index + 1; nextIndex < particles.length; nextIndex += 1) {
          const next = particles[nextIndex];
          const dx = particle.x - next.x;
          const dy = particle.y - next.y;
          const distance = Math.sqrt(dx * dx + dy * dy);

          if (distance < 118) {
            context.beginPath();
            context.moveTo(particle.x, particle.y);
            context.lineTo(next.x, next.y);
            context.strokeStyle = `rgba(88, 216, 255, ${(1 - distance / 118) * 0.075})`;
            context.lineWidth = 0.6;
            context.stroke();
          }
        }
      });

      if (!reducedMotion) {
        animationFrame = window.requestAnimationFrame(drawParticles);
      }
    };

    resizeCanvas();
    drawParticles();

    window.addEventListener("resize", () => {
      window.cancelAnimationFrame(animationFrame);
      resizeCanvas();
      drawParticles();
    });
  }
</script>
