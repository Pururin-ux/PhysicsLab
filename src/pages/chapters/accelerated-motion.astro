---
import BaseLayout from "../../layouts/BaseLayout.astro";
import AccelerationScene from "../../components/simulations/AccelerationScene.astro";
import MathFormula from "../../components/math/MathFormula.astro";
import SurfaceCard from "../../components/ui/SurfaceCard.astro";

const navItems = [
  { href: "#predict", label: "Сначала" },
  { href: "#lab", label: "Лаборатория" },
  { href: "#formula", label: "Формулы" },
  { href: "#check", label: "Проверка" }
];
---

<BaseLayout
  title="Равноускоренное движение — PhysicsLab"
  description="Интерактивная глава о равноускоренном движении: проверь, как ускорение меняет скорость, график v(t) и координату x(t)."
  navItems={navItems}
  brandHref="/chapters/accelerated-motion/"
  brandLabel="Глава: Равноускоренное движение"
>
  <article
    class="chapter-page"
    data-accelerated-motion-chapter
    data-release-stage="prototype-v0"
    data-review-status="author-review-required"
  >
    <section class="section chapter-intro" aria-labelledby="chapter-title">
      <div>
        <h1 id="chapter-title">Равноускоренное движение</h1>
        <p class="chapter-lead">
          Сначала запусти движение, потом меняй ускорение a. Смотри не только на точку,
          но и на график v(t): именно там видно, как скорость меняется.
        </p>
      </div>
      <aside class="chapter-note">
        <strong>Главная мысль</strong>
        <p>
          Ускорение не просто означает “быстрее”. Оно показывает, как меняется скорость:
          растёт, уменьшается или меняет знак.
        </p>
      </aside>
    </section>

    <section id="predict" class="section chapter-section" aria-labelledby="predict-title">
      <SurfaceCard>
        <div class="prediction-panel" data-acceleration-predict>
          <div>
            <p class="eyebrow">Сначала подумай</p>
            <h2 id="predict-title">Как сначала поведёт себя тело?</h2>
            <p>
              Ответь без расчёта. Потом проверь ответ в лаборатории.
            </p>
          </div>

          <div
            class="prediction-question"
            data-feedback-correct="Да. Ускорение влево опускает линию скорости, но пока скорость положительная, тело ещё едет вправо."
            data-feedback-wrong="Не совсем. Сначала смотри на знак скорости. Пока скорость положительная, тело движется вправо."
          >
            <p class="prediction-prompt">Тело сначала едет вправо, а ускорение направлено влево. Что сначала будет происходить?</p>
            <div class="chapter-answer-row prediction-answer-row" role="group" aria-label="Варианты ответа">
              <button type="button" data-prediction-answer="correct" aria-pressed="false">
                Ещё едет вправо, но замедляется
              </button>
              <button type="button" data-prediction-answer="instant-back" aria-pressed="false">
                Сразу едет назад
              </button>
              <button type="button" data-prediction-answer="instant-stop" aria-pressed="false">
                Остановится мгновенно
              </button>
              <button type="button" data-prediction-answer="speed-up" aria-pressed="false">
                Будет ехать вправо всё быстрее
              </button>
            </div>
            <p class="chapter-feedback prediction-feedback" data-prediction-feedback aria-live="polite">
              Выбери ответ. Потом сравни с графиком скорости.
            </p>
            <p class="prediction-next-step" data-prediction-hint hidden>
              Теперь выставь ускорение влево и смотри, когда линия скорости пересечёт ноль.
            </p>
          </div>

          <div class="prediction-grid" aria-label="На что смотреть в лаборатории">
            <article>
              <strong>Сначала скорость</strong>
              <p>Пока скорость положительная, тело едет вправо.</p>
            </article>
            <article>
              <strong>Потом координата</strong>
              <p>Когда скорость меняется, линия координаты изгибается.</p>
            </article>
          </div>
        </div>
      </SurfaceCard>
    </section>

    <section id="lab" class="section chapter-section" aria-labelledby="lab-title">
      <div class="chapter-section__head">
        <p class="eyebrow">Лаборатория</p>
        <h2 id="lab-title">Теперь проверь руками</h2>
        <p>
          Нажми «Запустить». Потом подвигай a: сначала в плюс, потом в минус. Следи за v(t),
          а уже потом за x(t).
        </p>
      </div>
      <AccelerationScene />
    </section>

    <section id="formula" class="section chapter-section" aria-labelledby="formula-title">
      <SurfaceCard>
        <p class="eyebrow">После наблюдения</p>
        <h2 id="formula-title">От наблюдения к формуле</h2>
        <p class="formula-intro">
          Сначала свяжи скорость с графиком v(t). Затем проверь координату, единицы и знак на одной подстановке.
        </p>
        <div class="formula-grid">
          <div class="formula-card">
            <span class="formula-step">Скорость</span>
            <div class="formula">
              <MathFormula tex="v = v_0 + at" display />
            </div>
            <p>
              v₀ — скорость в начале. at — изменение скорости за время t.
              На графике v(t) это видно как наклон.
            </p>
          </div>
          <div class="formula-card">
            <span class="formula-step">Координата</span>
            <div class="formula">
              <MathFormula tex={"x = x_0 + v_0 t + \\frac{a t^2}{2}"} display />
            </div>
            <p>
              x зависит от скорости. Если скорость меняется, наклон x(t) тоже меняется,
              и линия становится кривой.
            </p>
          </div>
        </div>

        <div class="formula-worked-example" data-formula-worked-example>
          <div class="formula-worked-example__header">
            <span class="formula-step">Одна подстановка</span>
            <h3>Скорость через 1 секунду</h3>
          </div>
          <div class="formula-worked-example__flow">
            <div class="worked-step worked-step--givens">
              <span class="worked-step__label">Дано</span>
              <div class="formula-worked-example__givens" aria-label="Дано">
                <span class="formula-worked-example__given"><b>v₀</b> = 3 м/с</span>
                <span class="formula-worked-example__given"><b>a</b> = −2 м/с²</span>
                <span class="formula-worked-example__given"><b>t</b> = 1 с</span>
              </div>
            </div>

            <div class="worked-step worked-step--substitution">
              <span class="worked-step__label">Подставляем</span>
              <div class="formula">
                <MathFormula tex={"v = 3 + (-2)\\cdot 1 = 1"} display />
              </div>
            </div>

            <div class="worked-step worked-step--result">
              <span class="worked-step__label">Получаем</span>
              <p><strong>v = 1 м/с</strong></p>
            </div>

            <div class="worked-step worked-step--meaning" aria-label="Проверка единиц и направления">
              <span class="worked-step__label">Значит</span>
              <ul>
                <li><strong>Единицы:</strong> (м/с²) · с = м/с, поэтому at можно прибавлять к скорости.</li>
                <li><strong>Знак:</strong> v всё ещё положительная — тело движется вправо.</li>
                <li><strong>Ускорение против скорости:</strong> скорость уменьшается.</li>
                <li>Направление задаёт знак v.</li>
              </ul>
            </div>
          </div>
        </div>
        <div class="formula-meta" aria-label="Справочник по переменным, единицам и условию применимости">
          <div class="formula-reference">
            <span class="formula-reference__label">Справочник</span>
            <h3>Переменные и единицы</h3>
            <div class="variable-grid">
              <span class="variable-chip" data-formula-variable="v" data-variable="v" data-var="v"><b>v</b> скорость <em>м/с</em></span>
              <span class="variable-chip" data-formula-variable="v0" data-variable="v" data-var="v"><b>v₀</b> начальная скорость <em>м/с</em></span>
              <span class="variable-chip" data-formula-variable="a" data-variable="a" data-var="a"><b>a</b> ускорение <em>м/с²</em></span>
              <span class="variable-chip" data-formula-variable="t" data-variable="t" data-var="t"><b>t</b> время <em>с</em></span>
              <span class="variable-chip" data-formula-variable="x" data-variable="x" data-var="x"><b>x</b> координата <em>м</em></span>
              <span class="variable-chip" data-formula-variable="x0" data-variable="x" data-var="x"><b>x₀</b> начальная координата <em>м</em></span>
            </div>
          </div>
          <div class="formula-condition formula-reference">
            <span class="formula-reference__label">Можно подсмотреть</span>
            <h3>Короткие условия</h3>
            <div class="condition-note-grid" aria-label="Условия применения формул">
              <article class="condition-note" data-formula-condition-note="axis">
                <strong>Ось</strong>
                <p>Вправо считаем положительным направлением. Знаки x, v и a — проекции на эту ось.</p>
              </article>
              <article class="condition-note" data-formula-condition-note="direction">
                <strong>Направление</strong>
                <p>v &gt; 0 — движение вправо. v &lt; 0 — назад. Ускорение a меняет v.</p>
              </article>
              <article class="condition-note" data-formula-condition-note="coordinate">
                <strong>Координата</strong>
                <p>x — положение на оси. Δx = x - x₀ — перемещение.</p>
              </article>
              <article class="condition-note condition-note--accent" data-formula-condition-note="constant-a">
                <strong>Условие</strong>
                <p>Формулы подходят, если ускорение a постоянно. Если a меняется во времени, нужна другая модель.</p>
              </article>
              <article class="condition-note" data-formula-condition-note="lab">
                <strong>В этой лаборатории</strong>
                <p>x₀ зафиксировано как 0, чтобы фокус был на v₀ и a.</p>
              </article>
            </div>
          </div>
        </div>
      </SurfaceCard>
    </section>

    <section id="check" class="section chapter-section" aria-labelledby="check-title">
      <SurfaceCard>
        <div
          class="chapter-check"
          data-acceleration-check
          data-feedback-correct="Да. После пересечения нуля скорость стала отрицательной: точка едет назад, а координата уменьшается."
          data-feedback-wrong="Не совсем. Направление задаёт знак скорости v. Если v(t) уже ниже нуля, движение идёт назад, даже если старт был вправо."
        >
          <div>
            <p class="eyebrow">Перенос на задачу</p>
            <h2 id="check-title">v(t) пересекла ноль и стала ниже оси. Что теперь делает тело?</h2>
          </div>
          <div class="chapter-answer-row" role="group" aria-label="Варианты ответа">
            <button type="button" data-check-answer="correct" aria-pressed="false">
              Едет назад: координата уменьшается
            </button>
            <button type="button" data-check-answer="start-wins" aria-pressed="false">
              Всё ещё вправо, потому что v₀ было положительным
            </button>
            <button type="button" data-check-answer="stopped" aria-pressed="false">
              Остановилось навсегда
            </button>
          </div>
          <p class="chapter-feedback" data-check-feedback aria-live="polite">
            Выбери вариант и проверь себя по положению линии v(t) относительно нуля.
          </p>
        </div>
      </SurfaceCard>
    </section>
  </article>
</BaseLayout>

<script>
  setupChoiceBlock({
    rootSelector: "[data-acceleration-predict] .prediction-question",
    buttonSelector: "[data-prediction-answer]",
    answerAttribute: "data-prediction-answer",
    feedbackSelector: "[data-prediction-feedback]",
    hintSelector: "[data-prediction-hint]"
  });

  setupChoiceBlock({
    rootSelector: "[data-acceleration-check]",
    buttonSelector: "[data-check-answer]",
    answerAttribute: "data-check-answer",
    feedbackSelector: "[data-check-feedback]"
  });

  type ChoiceBlockOptions = {
    rootSelector: string;
    buttonSelector: string;
    answerAttribute: string;
    feedbackSelector: string;
    hintSelector?: string;
  };

  function setupChoiceBlock(options: ChoiceBlockOptions) {
    document.querySelectorAll<HTMLElement>(options.rootSelector).forEach((block) => {
      const buttons = block.querySelectorAll<HTMLButtonElement>(options.buttonSelector);
      const feedback = block.querySelector<HTMLElement>(options.feedbackSelector);
      const hint = options.hintSelector
        ? block.querySelector<HTMLElement>(options.hintSelector)
        : null;
      const correctFeedback = block.dataset.feedbackCorrect ?? "";
      const wrongFeedback = block.dataset.feedbackWrong ?? "";

      buttons.forEach((button) => {
        button.addEventListener("click", () => {
          const isCorrect = button.getAttribute(options.answerAttribute) === "correct";
          buttons.forEach((item) => {
            item.classList.remove("is-correct", "is-wrong");
            item.setAttribute("aria-pressed", "false");
          });
          button.classList.add(isCorrect ? "is-correct" : "is-wrong");
          button.setAttribute("aria-pressed", "true");

          if (feedback) {
            feedback.dataset.state = isCorrect ? "success" : "warning";
            feedback.textContent = isCorrect ? correctFeedback : wrongFeedback;
          }

          if (hint) {
            hint.hidden = false;
          }
        });
      });
    });
  }

</script>

<style>
  .chapter-page {
    min-width: 0;
  }

  :global(.topbar) {
    border-bottom-color: rgba(88, 216, 255, 0.12);
    background:
      linear-gradient(90deg, rgba(8, 14, 24, 0.62), rgba(8, 14, 24, 0.28)),
      transparent;
    backdrop-filter: blur(14px);
  }

  :global(.topbar nav a) {
    background: rgba(8, 14, 24, 0.28);
  }

  :global(#lab-background-canvas) {
    width: 100% !important;
  }

  .chapter-intro {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(250px, 0.38fr);
    gap: var(--pl-space-5);
    align-items: end;
    padding-bottom: var(--pl-space-10);
  }

  .chapter-page > .section {
    padding-block: clamp(var(--pl-space-10), 5.2vw, var(--pl-space-16));
  }

  .chapter-page > .chapter-intro {
    padding-top: clamp(var(--pl-space-16), 7vw, var(--pl-space-20));
    padding-bottom: clamp(var(--pl-space-8), 4vw, var(--pl-space-12));
  }

  .chapter-intro h1 {
    margin-top: var(--pl-space-4);
    margin-bottom: var(--pl-space-4);
    overflow-wrap: anywhere;
  }

  .chapter-lead {
    max-width: 780px;
    margin-bottom: 0;
    color: var(--pl-text);
    font-size: clamp(1.08rem, 1.9vw, 1.28rem);
    line-height: 1.55;
  }

  .chapter-note {
    padding: var(--pl-space-4);
    border: 1px solid rgba(255, 216, 77, 0.18);
    border-radius: 20px;
    background:
      linear-gradient(135deg, rgba(255, 216, 77, 0.08), transparent 58%),
      rgba(16, 23, 34, 0.78);
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.025),
      inset 0 0 26px rgba(255, 216, 77, 0.025);
  }

  .chapter-note strong {
    display: block;
    margin-bottom: var(--pl-space-2);
    color: var(--pl-accent);
  }

  .chapter-note p {
    margin: 0;
    font-size: 0.98rem;
  }

  .chapter-section {
    display: grid;
    gap: var(--pl-space-5);
  }

  .chapter-section__head {
    max-width: 820px;
  }

  .chapter-section__head p:last-child {
    margin-bottom: 0;
  }

  .chapter-page :global(.surface-card:not(.surface-card--lab)) {
    border-color: rgba(126, 179, 218, 0.12);
    border-radius: 22px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.032), rgba(255, 255, 255, 0.01)),
      rgba(7, 15, 28, 0.58);
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.022),
      inset 0 0 24px rgba(88, 216, 255, 0.016),
      0 16px 42px rgba(0, 0, 0, 0.16);
  }

  .prediction-panel {
    display: grid;
    gap: var(--pl-space-3);
  }

  .prediction-panel > div:first-child {
    max-width: 700px;
  }

  .prediction-panel > div:first-child p {
    max-width: 620px;
    margin-bottom: 0;
    line-height: 1.45;
  }

  .prediction-panel p:last-child {
    margin-bottom: 0;
  }

  .prediction-question {
    display: grid;
    gap: var(--pl-space-2);
    padding: clamp(var(--pl-space-3), 2vw, var(--pl-space-4));
    border: 1px solid rgba(255, 216, 77, 0.16);
    border-radius: 18px;
    background:
      linear-gradient(135deg, rgba(255, 216, 77, 0.075), rgba(88, 216, 255, 0.032)),
      rgba(255, 255, 255, 0.02);
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.024),
      inset 0 18px 48px rgba(255, 216, 77, 0.022);
  }

  .prediction-prompt {
    margin: 0;
    color: var(--pl-text);
    font-size: clamp(1.04rem, 2.1vw, 1.26rem);
    font-weight: 900;
    line-height: 1.3;
  }

  .prediction-answer-row button {
    flex-basis: 210px;
  }

  .prediction-next-step {
    margin: 0;
    padding: 9px 11px;
    border: 1px solid rgba(88, 216, 255, 0.14);
    border-radius: 14px;
    color: var(--pl-text);
    background: rgba(88, 216, 255, 0.045);
    line-height: 1.38;
  }

  .prediction-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--pl-space-2);
  }

  .prediction-grid article {
    min-width: 0;
    padding: 10px 12px;
    border: 1px solid rgba(88, 216, 255, 0.1);
    border-radius: 14px;
    background:
      linear-gradient(180deg, rgba(88, 216, 255, 0.045), rgba(255, 255, 255, 0.012)),
      rgba(255, 255, 255, 0.018);
  }

  .prediction-grid strong {
    display: block;
    margin-bottom: 4px;
    color: var(--pl-accent);
    font-size: 0.9rem;
  }

  .prediction-grid p {
    margin: 0;
    font-size: 0.9rem;
    line-height: 1.38;
  }

  .formula-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--pl-space-3);
    margin-top: var(--pl-space-3);
  }

  .formula-intro {
    max-width: 760px;
    margin: var(--pl-space-2) 0 0;
    color: var(--pl-text-muted);
    line-height: 1.45;
  }

  .formula-step {
    display: block;
    margin: 0 0 var(--pl-space-2);
    color: var(--pl-accent);
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0;
    text-transform: uppercase;
  }

  .formula-card {
    min-width: 0;
    padding: var(--pl-space-3);
    border: 1px solid rgba(88, 216, 255, 0.14);
    border-radius: 16px;
    background:
      linear-gradient(180deg, rgba(88, 216, 255, 0.042), rgba(255, 255, 255, 0.012)),
      rgba(255, 255, 255, 0.022);
  }

  .formula {
    max-width: 100%;
    margin-bottom: var(--pl-space-3);
    color: var(--pl-text);
    min-width: 0;
    overflow-x: auto;
    overflow-y: hidden;
    overscroll-behavior-inline: contain;
  }

  .formula :global(.math-formula--display) {
    display: block;
    width: 100%;
    padding: 0;
  }

  .formula :global(.math-formula--display .katex-display) {
    text-align: left;
  }

  .formula :global(.math-formula--display .katex) {
    font-size: clamp(1.35rem, 3.1vw, 2.08rem);
    line-height: 1.18;
  }

  .formula-card p:last-child {
    margin-bottom: 0;
  }

  .formula-worked-example {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: var(--pl-space-2);
    margin-top: var(--pl-space-3);
    padding: var(--pl-space-3) var(--pl-space-3) var(--pl-space-3) var(--pl-space-4);
    border: 1px solid rgba(88, 216, 255, 0.16);
    border-radius: 16px;
    background:
      linear-gradient(135deg, rgba(110, 231, 168, 0.05), rgba(88, 216, 255, 0.032)),
      rgba(255, 255, 255, 0.018);
    box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.022);
  }

  .formula-worked-example::before {
    content: "";
    position: absolute;
    top: var(--pl-space-3);
    bottom: var(--pl-space-3);
    left: var(--pl-space-3);
    width: 3px;
    border-radius: 999px;
    background: linear-gradient(180deg, rgba(110, 231, 168, 0.85), rgba(88, 216, 255, 0.76));
  }

  .formula-worked-example__header,
  .formula-worked-example__flow,
  .worked-step {
    min-width: 0;
  }

  .formula-worked-example h3 {
    margin: 0;
    color: var(--pl-text);
    font-size: 1rem;
  }

  .formula-worked-example p {
    margin: 0;
    color: var(--pl-text-muted);
    font-size: 0.94rem;
    line-height: 1.43;
  }

  .formula-worked-example p + p {
    margin-top: var(--pl-space-2);
  }

  .formula-worked-example strong {
    color: var(--pl-text);
  }

  .formula-worked-example__flow {
    display: grid;
    grid-template-columns: minmax(190px, 0.8fr) minmax(250px, 1fr) minmax(160px, 0.55fr);
    gap: var(--pl-space-2);
    align-items: stretch;
  }

  .worked-step {
    display: grid;
    align-content: start;
    gap: 8px;
    padding: 10px 11px;
    border: 1px solid rgba(88, 216, 255, 0.1);
    border-radius: 12px;
    background: rgba(4, 13, 26, 0.28);
  }

  .worked-step--meaning {
