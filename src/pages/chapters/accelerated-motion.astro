---
import BaseLayout from "../../layouts/BaseLayout.astro";
import AccelerationScene from "../../components/simulations/AccelerationScene.astro";
import Badge from "../../components/ui/Badge.astro";
import SurfaceCard from "../../components/ui/SurfaceCard.astro";

const navItems = [
  { href: "#predict", label: "Прогноз" },
  { href: "#lab", label: "Лаборатория" },
  { href: "#formula", label: "Формулы" },
  { href: "#check", label: "Проверка" }
];
---

<BaseLayout
  title="Равноускоренное движение — PhysicsLab"
  description="Low-fi прототип главы PhysicsLab про равноускоренное движение."
  navItems={navItems}
  brandHref="/chapters/accelerated-motion/"
  brandLabel="Глава: Равноускоренное движение"
>
  <article class="chapter-page" data-accelerated-motion-chapter>
    <section class="section chapter-intro" aria-labelledby="chapter-title">
      <div>
        <div class="chapter-meta" aria-label="Статус главы">
          <Badge tone="info">prototype v0</Badge>
          <Badge tone="accent">authorReviewRequired</Badge>
        </div>
        <h1 id="chapter-title">Равноускоренное движение</h1>
        <p class="chapter-lead">
          Сначала запусти движение, потом меняй ускорение a. Смотри не только на точку,
          но и на график v(t): именно там видно, как скорость меняется.
        </p>
      </div>
      <aside class="chapter-note">
        <strong>Главная мысль</strong>
        <p>
          Ускорение не просто означает “быстрее”. Оно показывает, как меняется скорость:
          растёт, уменьшается или меняет знак.
        </p>
      </aside>
    </section>

    <section id="predict" class="section chapter-section" aria-labelledby="predict-title">
      <SurfaceCard>
        <div class="prediction-panel" data-acceleration-predict>
          <div>
            <p class="eyebrow">Перед запуском</p>
            <h2 id="predict-title">Сначала сделай простой прогноз</h2>
            <p>
              Не считай. Сначала выбери догадку, а потом проверь её в лаборатории.
            </p>
          </div>

          <div
            class="prediction-question"
            data-feedback-correct="Да. Отрицательное a наклоняет v(t) вниз, но пока v > 0, тело ещё едет вправо."
            data-feedback-wrong="Не совсем. Сначала смотри на знак v, а не на знак a. Если v ещё положительная, тело движется вправо."
          >
            <p class="prediction-prompt">v₀ &gt; 0, но a &lt; 0. Что сначала будет с телом?</p>
            <div class="chapter-answer-row prediction-answer-row" role="group" aria-label="Варианты прогноза">
              <button type="button" data-prediction-answer="correct" aria-pressed="false">
                Ещё едет вправо, но замедляется
              </button>
              <button type="button" data-prediction-answer="instant-back" aria-pressed="false">
                Сразу едет назад
              </button>
              <button type="button" data-prediction-answer="instant-stop" aria-pressed="false">
                Остановится мгновенно
              </button>
              <button type="button" data-prediction-answer="straight-x" aria-pressed="false">
                x(t) обязан быть прямой
              </button>
            </div>
            <p class="chapter-feedback prediction-feedback" data-prediction-feedback aria-live="polite">
              Выбери прогноз. Потом сравни его с графиком v(t).
            </p>
            <p class="prediction-next-step" data-prediction-hint hidden>
              Теперь выставь a &lt; 0 и смотри, когда v(t) пересечёт ноль.
            </p>
          </div>

          <div class="prediction-grid" aria-label="На что смотреть в лаборатории">
            <article>
              <strong>Сначала v(t)</strong>
              <p>Знак скорости показывает направление, а наклон показывает ускорение.</p>
            </article>
            <article>
              <strong>Потом x(t)</strong>
              <p>Если скорость меняется, наклон x(t) тоже меняется.</p>
            </article>
          </div>
        </div>
      </SurfaceCard>
    </section>

    <section id="lab" class="section chapter-section" aria-labelledby="lab-title">
      <div class="chapter-section__head">
        <p class="eyebrow">Лаборатория</p>
        <h2 id="lab-title">Теперь проверь руками</h2>
        <p>
          Нажми «Запустить». Потом подвигай a: сначала в плюс, потом в минус. Следи за v(t),
          а уже потом за x(t).
        </p>
      </div>
      <AccelerationScene />
    </section>

    <section id="formula" class="section chapter-section" aria-labelledby="formula-title">
      <SurfaceCard>
        <p class="eyebrow">После наблюдения</p>
        <h2 id="formula-title">Формулы записывают то, что ты увидел</h2>
        <div class="formula-grid">
          <div class="formula-card">
            <p class="formula">v = v₀ + at</p>
            <p>
              v₀ — скорость в начале. at — насколько скорость изменилась за время t.
              Поэтому на графике v(t) ускорение видно как наклон.
            </p>
          </div>
          <div class="formula-card">
            <p class="formula">x = x₀ + v₀t + at²/2</p>
            <p>
              Координата зависит не только от стартовой скорости: ускорение меняет скорость,
              поэтому линия x(t) изгибается.
            </p>
          </div>
        </div>
        <p class="formula-note">
          Частая ловушка: a &lt; 0 не означает «сразу назад». Сначала посмотри на v(t):
          пока v положительная, тело ещё едет вправо.
        </p>
      </SurfaceCard>
    </section>

    <section id="check" class="section chapter-section" aria-labelledby="check-title">
      <SurfaceCard>
        <div
          class="chapter-check"
          data-acceleration-check
          data-feedback-correct="Да. После пересечения нуля скорость стала отрицательной: точка едет назад, а координата уменьшается."
          data-feedback-wrong="Не совсем. Направление задаёт знак скорости v. Если v(t) уже ниже нуля, движение идёт назад, даже если старт был вправо."
        >
          <div>
            <p class="eyebrow">Перенос на задачу</p>
            <h2 id="check-title">v(t) пересекла ноль и стала ниже оси. Что теперь делает тело?</h2>
          </div>
          <div class="chapter-answer-row" role="group" aria-label="Варианты ответа">
            <button type="button" data-check-answer="correct" aria-pressed="false">
              Едет назад: координата уменьшается
            </button>
            <button type="button" data-check-answer="start-wins" aria-pressed="false">
              Всё ещё вправо, потому что v₀ было положительным
            </button>
            <button type="button" data-check-answer="stopped" aria-pressed="false">
              Остановилось навсегда
            </button>
          </div>
          <p class="chapter-feedback" data-check-feedback aria-live="polite">
            Выбери вариант и проверь себя по положению линии v(t) относительно нуля.
          </p>
        </div>
      </SurfaceCard>
    </section>
  </article>
</BaseLayout>

<script>
  setupChoiceBlock({
    rootSelector: "[data-acceleration-predict] .prediction-question",
    buttonSelector: "[data-prediction-answer]",
    answerAttribute: "data-prediction-answer",
    feedbackSelector: "[data-prediction-feedback]",
    hintSelector: "[data-prediction-hint]"
  });

  setupChoiceBlock({
    rootSelector: "[data-acceleration-check]",
    buttonSelector: "[data-check-answer]",
    answerAttribute: "data-check-answer",
    feedbackSelector: "[data-check-feedback]"
  });

  type ChoiceBlockOptions = {
    rootSelector: string;
    buttonSelector: string;
    answerAttribute: string;
    feedbackSelector: string;
    hintSelector?: string;
  };

  function setupChoiceBlock(options: ChoiceBlockOptions) {
    document.querySelectorAll<HTMLElement>(options.rootSelector).forEach((block) => {
      const buttons = block.querySelectorAll<HTMLButtonElement>(options.buttonSelector);
      const feedback = block.querySelector<HTMLElement>(options.feedbackSelector);
      const hint = options.hintSelector
        ? block.querySelector<HTMLElement>(options.hintSelector)
        : null;
      const correctFeedback = block.dataset.feedbackCorrect ?? "";
      const wrongFeedback = block.dataset.feedbackWrong ?? "";

      buttons.forEach((button) => {
        button.addEventListener("click", () => {
          const isCorrect = button.getAttribute(options.answerAttribute) === "correct";
          buttons.forEach((item) => {
            item.classList.remove("is-correct", "is-wrong");
            item.setAttribute("aria-pressed", "false");
          });
          button.classList.add(isCorrect ? "is-correct" : "is-wrong");
          button.setAttribute("aria-pressed", "true");

          if (feedback) {
            feedback.dataset.state = isCorrect ? "success" : "warning";
            feedback.textContent = isCorrect ? correctFeedback : wrongFeedback;
          }

          if (hint) {
            hint.hidden = false;
          }
        });
      });
    });
  }
</script>

<style>
  .chapter-page {
    min-width: 0;
  }

  .chapter-page :global(.badge) {
    max-width: 100%;
    overflow-wrap: anywhere;
    white-space: normal;
  }

  :global(.topbar) {
    border-bottom-color: rgba(88, 216, 255, 0.12);
    background:
      linear-gradient(90deg, rgba(8, 14, 24, 0.62), rgba(8, 14, 24, 0.28)),
      transparent;
    backdrop-filter: blur(14px);
  }

  :global(.topbar nav a) {
    background: rgba(8, 14, 24, 0.28);
  }

  :global(#lab-background-canvas) {
    width: 100% !important;
  }

  .chapter-intro {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(250px, 0.38fr);
    gap: var(--pl-space-5);
    align-items: end;
    padding-bottom: var(--pl-space-10);
  }

  .chapter-intro h1 {
    margin-top: var(--pl-space-4);
    margin-bottom: var(--pl-space-4);
    overflow-wrap: anywhere;
  }

  .chapter-lead {
    max-width: 780px;
    margin-bottom: 0;
    color: var(--pl-text);
    font-size: clamp(1.08rem, 1.9vw, 1.28rem);
    line-height: 1.55;
  }

  .chapter-note {
    padding: var(--pl-space-4);
    border: 1px solid rgba(255, 216, 77, 0.18);
    border-radius: 20px;
    background:
      linear-gradient(135deg, rgba(255, 216, 77, 0.08), transparent 58%),
      rgba(16, 23, 34, 0.78);
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.025),
      inset 0 0 26px rgba(255, 216, 77, 0.025);
  }

  .chapter-note strong {
    display: block;
    margin-bottom: var(--pl-space-2);
    color: var(--pl-accent);
  }

  .chapter-note p {
    margin: 0;
    font-size: 0.98rem;
  }

  .chapter-section {
    display: grid;
    gap: var(--pl-space-5);
  }

  .chapter-section__head {
    max-width: 820px;
  }

  .chapter-section__head p:last-child {
    margin-bottom: 0;
  }

  .chapter-page :global(.surface-card:not(.surface-card--lab)) {
    border-color: rgba(126, 179, 218, 0.12);
    border-radius: 22px;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.032), rgba(255, 255, 255, 0.01)),
      rgba(7, 15, 28, 0.58);
    box-shadow:
      inset 0 0 0 1px rgba(255, 255, 255, 0.022),
      inset 0 0 24px rgba(88, 216, 255, 0.016),
      0 16px 42px rgba(0, 0, 0, 0.16);
  }

  .prediction-panel {
    display: grid;
    gap: var(--pl-space-4);
  }

  .prediction-panel > div:first-child {
    max-width: 760px;
  }

  .prediction-panel p:last-child {
    margin-bottom: 0;
  }

  .prediction-question {
    display: grid;
    gap: var(--pl-space-3);
    padding: var(--pl-space-4);
    border: 1px solid rgba(255, 216, 77, 0.12);
    border-radius: 18px;
    background:
      linear-gradient(135deg, rgba(255, 216, 77, 0.06), rgba(88, 216, 255, 0.026)),
      rgba(255, 255, 255, 0.018);
  }

  .prediction-prompt {
    margin: 0;
    color: var(--pl-text);
    font-size: clamp(1.08rem, 2.4vw, 1.35rem);
    font-weight: 900;
    line-height: 1.35;
  }

  .prediction-answer-row button {
    flex-basis: 210px;
  }

  .prediction-next-step {
    margin: 0;
    padding: var(--pl-space-3);
    border: 1px solid rgba(88, 216, 255, 0.14);
    border-radius: 14px;
    color: var(--pl-text);
    background: rgba(88, 216, 255, 0.045);
    line-height: 1.5;
  }

  .prediction-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--pl-space-3);
  }

  .prediction-grid article {
    min-width: 0;
    padding: var(--pl-space-3);
    border: 1px solid rgba(88, 216, 255, 0.1);
    border-radius: 16px;
    background:
      linear-gradient(180deg, rgba(88, 216, 255, 0.045), rgba(255, 255, 255, 0.012)),
      rgba(255, 255, 255, 0.018);
  }

  .prediction-grid strong {
    display: block;
    margin-bottom: var(--pl-space-2);
    color: var(--pl-accent);
  }

  .prediction-grid p {
    margin: 0;
    line-height: 1.48;
  }

  .formula-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--pl-space-4);
  }

  .formula-card {
    min-width: 0;
    padding: var(--pl-space-4);
    border: 1px solid rgba(88, 216, 255, 0.14);
    border-radius: 18px;
    background: rgba(255, 255, 255, 0.026);
  }

  .formula {
    max-width: 100%;
    margin-bottom: var(--pl-space-3);
    color: var(--pl-text);
    font-family: "Cascadia Mono", "JetBrains Mono", Consolas, monospace;
    font-size: clamp(1.5rem, 4vw, 2.35rem);
    font-weight: 900;
    line-height: 1.14;
    overflow-wrap: anywhere;
  }

  .formula-card p:last-child {
    margin-bottom: 0;
  }

  .formula-note {
    margin: var(--pl-space-4) 0 0;
    padding: var(--pl-space-3);
    border: 1px solid rgba(255, 216, 77, 0.14);
    border-radius: 16px;
    color: var(--pl-text);
    background: rgba(255, 216, 77, 0.045);
    line-height: 1.55;
  }

  .chapter-check {
    display: grid;
    gap: var(--pl-space-4);
  }

  .chapter-answer-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--pl-space-3);
  }

  .chapter-answer-row button {
    flex: 1 1 190px;
    min-height: 46px;
    padding: 10px 12px;
    border: 1px solid rgba(88, 216, 255, 0.12);
    border-radius: 14px;
    color: var(--pl-text);
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.045), rgba(255, 255, 255, 0.012)),
      rgba(5, 14, 27, 0.66);
    font-weight: 900;
    text-align: left;
  }

  .chapter-answer-row button:focus-visible {
    outline: 3px solid var(--pl-accent);
    outline-offset: 4px;
  }

  .chapter-answer-row button.is-correct {
    border-color: rgba(110, 231, 168, 0.72);
    color: var(--pl-green);
    background: rgba(110, 231, 168, 0.08);
  }

  .chapter-answer-row button.is-wrong {
    border-color: rgba(255, 107, 107, 0.62);
    color: var(--pl-red);
    background: rgba(255, 107, 107, 0.08);
  }

  .chapter-feedback {
    min-height: 1.6em;
    margin: 0;
    padding: var(--pl-space-3);
    border: 1px solid rgba(88, 216, 255, 0.12);
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.026);
  }

  .chapter-feedback[data-state="success"] {
    border-color: rgba(110, 231, 168, 0.5);
  }

  .chapter-feedback[data-state="warning"] {
    border-color: rgba(255, 107, 107, 0.45);
  }

  @media (max-width: 900px) {
    .chapter-intro,
    .prediction-grid,
    .formula-grid {
      grid-template-columns: minmax(0, 1fr);
    }

    .chapter-intro > *,
    .prediction-grid > *,
    .formula-grid > * {
      min-width: 0;
    }
  }

  @media (max-width: 600px) {
    .chapter-intro {
      padding-top: var(--pl-space-10);
      padding-bottom: var(--pl-space-6);
    }

    .chapter-intro h1 {
      font-size: clamp(1.72rem, 8.4vw, 2.35rem);
    }

    .chapter-answer-row {
      display: grid;
      grid-template-columns: 1fr;
    }
  }
</style>
