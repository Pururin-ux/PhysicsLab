---
import "../styles/global.css";

type NavItem = {
  href: string;
  label: string;
};

interface Props {
  title?: string;
  description?: string;
  navItems?: NavItem[];
  showBackground?: boolean;
  brandHref?: string;
  brandLabel?: string;
}

const {
  title = "PhysicsLab 2.0",
  description = "PhysicsLab 2.0: Astro-основа в направлении Dark Anime Lab.",
  showBackground = true,
  brandHref = "/lab-preview/",
  brandLabel = "Демо PhysicsLab 2.0",
  navItems = [
    { href: "/lab-preview/#learning", label: "Как учим" },
    { href: "/lab-preview/#modules", label: "Модули" },
    { href: "/lab-preview/#chapter-demo", label: "Демо-глава" },
    { href: "/lab-preview/#exam-layer", label: "ЦЭ/ЦТ" }
  ]
} = Astro.props;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    {showBackground && <canvas id="lab-background-canvas" aria-hidden="true"></canvas>}
    <header class="topbar" aria-label="Навигация PhysicsLab">
      <a class="brand" href={brandHref} aria-label={brandLabel}>
        <span class="brand-mark" aria-hidden="true">PL</span>
        <span>PhysicsLab 2.0</span>
      </a>
      <nav aria-label="Разделы страницы">
        {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
      </nav>
    </header>
    <main>
      <slot />
    </main>
    {showBackground && (
    <script>
      type BackgroundParticle = {
        x: number;
        y: number;
        vx: number;
        vy: number;
        r: number;
        accent: boolean;
      };

      const canvas = document.getElementById("lab-background-canvas");
      const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

      if (canvas instanceof HTMLCanvasElement) {
        const context = canvas.getContext("2d");

        if (!context) {
          throw new Error("PhysicsLab background canvas is unavailable.");
        }

        const palette = {
          cyan: "88, 216, 255",
          gold: "255, 216, 77",
          blue: "120, 160, 220"
        };
        let width = 0;
        let height = 0;
        let particles: BackgroundParticle[] = [];
        let animationFrame = 0;

        const resize = () => {
          const scale = Math.min(window.devicePixelRatio || 1, 1.5);
          width = window.innerWidth;
          height = window.innerHeight;
          canvas.width = Math.floor(width * scale);
          canvas.height = Math.floor(height * scale);
          canvas.style.width = `${width}px`;
          canvas.style.height = `${height}px`;
          context.setTransform(scale, 0, 0, scale, 0, 0);
        };

        const createParticles = () => {
          const count = Math.min(46, Math.max(24, Math.floor(width / 34)));
          particles = Array.from({ length: count }, (_, index) => ({
            x: Math.random() * width,
            y: Math.random() * height,
            vx: (Math.random() - 0.5) * 0.18,
            vy: (Math.random() - 0.5) * 0.18,
            r: Math.random() * 1.4 + 0.5,
            accent: index % 9 === 0
          }));
        };

        const draw = () => {
          context.clearRect(0, 0, width, height);
          for (let i = 0; i < particles.length; i += 1) {
            const point = particles[i];

            if (!reducedMotion.matches) {
              point.x += point.vx;
              point.y += point.vy;
              if (point.x < 0) point.x = width;
              if (point.x > width) point.x = 0;
              if (point.y < 0) point.y = height;
              if (point.y > height) point.y = 0;
            }

            context.beginPath();
            context.arc(point.x, point.y, point.r, 0, Math.PI * 2);
            context.fillStyle = point.accent
              ? `rgba(${palette.gold}, 0.34)`
              : `rgba(${palette.cyan}, 0.24)`;
            context.fill();

            for (let j = i + 1; j < particles.length; j += 1) {
              const next = particles[j];
              const dx = point.x - next.x;
              const dy = point.y - next.y;
              const distance = Math.sqrt(dx * dx + dy * dy);

              if (distance < 132) {
                context.beginPath();
                context.moveTo(point.x, point.y);
                context.lineTo(next.x, next.y);
                context.strokeStyle = `rgba(${palette.blue}, ${(1 - distance / 132) * 0.12})`;
                context.lineWidth = 0.7;
                context.stroke();
              }
            }
          }

          if (!reducedMotion.matches) {
            animationFrame = window.requestAnimationFrame(draw);
          }
        };

        const restart = () => {
          window.cancelAnimationFrame(animationFrame);
          resize();
          createParticles();
          draw();
        };

        restart();
        window.addEventListener("resize", restart, { passive: true });
        reducedMotion.addEventListener("change", restart);
        document.addEventListener("visibilitychange", () => {
          if (document.hidden) {
            window.cancelAnimationFrame(animationFrame);
          } else {
            restart();
          }
        });
      }
    </script>
    )}
  </body>
</html>
