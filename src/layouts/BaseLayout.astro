---
import "../styles/global.css";

type NavItem = {
  href: string;
  label: string;
};

interface Props {
  title?: string;
  description?: string;
  navItems?: NavItem[];
}

const {
  title = "PhysicsLab 2.0",
  description = "PhysicsLab 2.0: Astro-основа в направлении Dark Anime Lab.",
  navItems = [
    { href: "/lab-preview/#learning", label: "Как учим" },
    { href: "/lab-preview/#modules", label: "Модули" },
    { href: "/lab-preview/#chapter-demo", label: "Демо-глава" },
    { href: "/lab-preview/#exam-layer", label: "ЦЭ/ЦТ" }
  ]
} = Astro.props;
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <header class="topbar" aria-label="Навигация PhysicsLab">
      <a class="brand" href="/lab-preview/" aria-label="Демо PhysicsLab 2.0">
        <span class="brand-mark" aria-hidden="true">PL</span>
        <span>PhysicsLab 2.0</span>
      </a>
      <nav aria-label="Разделы страницы">
        {navItems.map((item) => <a href={item.href}>{item.label}</a>)}
      </nav>
    </header>
    <main>
      <slot />
    </main>
  </body>
</html>
